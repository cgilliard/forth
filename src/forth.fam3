# Forth compiler for RV32I — reads Forth source from UART, outputs binary to UART.
# Assembled by tools/asm.py into src/forth.fam0 for bootstrapping via fam0.
#
# Register allocation (compiler itself):
#   s1  (x9)  = input buffer read pointer (current parse position)
#   s2  (x18) = input buffer end (after last byte read)
#   s3  (x19) = output buffer write pointer (code emission)
#   s4  (x20) = dictionary pointer (next free entry)
#   s5  (x21) = UART base (0x10000000)
#   s6  (x22) = word buffer pointer (base, fixed)
#   s7  (x23) = word length (after parsing a word)
#   s8  (x24) = output buffer base (fixed, for offset calculations)
#   s9  (x25) = compile-time control stack pointer
#   s10 (x26) = dispatch ID counter (next call site ID to assign)
#   s11 (x27) = patch list pointer (records locations of jal-to-dispatch)
#   gp  (x3)  = line number counter (starts at 1)
#   tp  (x4)  = inside-definition flag (0=outside, 1=inside : ... ;)
#   t0-t6     = temporaries
#
# Compiled program register convention:
#   s1  (x9)  = dispatch return ID
#   s2  (x18) = shadow stack (return stack) pointer
#   s3  (x19) = TOS (top of data stack, cached in register)
#   s4  (x20) = data stack pointer (rest of stack)
#   s5  (x21) = UART base (0x10000000)
#   s6  (x22) = data stack lower limit (here+64MB, overflow check)
#   s7  (x23) = data stack upper limit (here+72MB, underflow check)
#   s8  (x24) = shadow stack upper limit (here+73MB, overflow check)
#   s9  (x25) = store protection boundary (here, code/heap boundary)
#   s10 (x26) = shadow stack base (here+72MB, underflow check)
#   t0-t6     = temporaries used by primitives
#   ra  (x1)  = [compiler only] error handler output address for runtime checks
#
# Memory map (compiler):
#   0x80000000           = load address (this compiler, or compiled program)
#   0x82000000           = dictionary (36 bytes per entry: 32 name + 4 addr)
#   0x82800000           = word parse buffer (256 bytes)
#   0x82800100           = control flow stack (compile-time, 4096 bytes)
#   0x82801100           = leave scratch (temporary storage during loop/if compilation)
#   0x82810000           = patch list (addresses needing dispatch fixup, 256KB)
#   0x82850000           = call site list (target addresses for dispatch table, 256KB)
#   0x83000000           = input buffer (source code)
#   0x84000000           = output buffer (compiled binary)
#
# Compiled program memory map (position-independent, all relative to here):
#   load_addr            = code start
#   here (end of binary) = heap pointer variable (4 bytes), then heap (64MB)
#   here + 64MB          = data stack lower limit (overflow guard)
#   here + 72MB          = data stack top / shadow stack base
#   here + 73MB          = shadow stack upper limit (overflow guard)
#   Computed at bye via auipc. Data stack: 8MB down. Shadow: 1MB up.

# ============================================================================
# PHASE 1: Read all input from UART into input buffer
# ============================================================================
_start:
    lui s5, 0x10000         # UART base = 0x10000000
    lui s1, 0x83000         # input buffer base
    addi s2, s1, 0          # s2 = write pointer (starts at base)

read_loop:
    lbu t5, 5(s5)           # Read UART Line Status Register
    andi t5, t5, 1          # Data Ready bit
    beqz t5, read_loop      # wait for data
    lbu t0, 0(s5)           # read byte
    addi t1, zero, 4        # EOT
    beq t0, t1, read_done   # end of input?
    sb t0, 0(s2)            # store in input buffer
    addi s2, s2, 1          # advance write pointer
    j read_loop

read_done:
# ============================================================================
# PHASE 2: Initialize compiler state
# ============================================================================
    # s1 = input read pointer (reset to start of input buffer)
    lui s1, 0x83000         # input read pointer = start
    # s3 = output write pointer
    lui s3, 0x84000         # output buffer base
    lui s8, 0x84000         # s8 = output base (kept for offset calc)
    # s4 = dictionary pointer
    lui s4, 0x82000         # dictionary base
    # s6 = word buffer base
    lui t0, 0x82800         # 0x82800000
    addi s6, t0, 0          # word buffer
    # s9 = control stack pointer
    addi s9, t0, 256        # 0x82800100
    # s11 = patch list pointer
    lui s11, 0x82810         # 0x82810000
    # s10 = dispatch ID counter (starts at 0)
    addi s10, zero, 0
    # gp = line number counter (starts at 1)
    addi gp, zero, 1
    # tp = inside-definition flag (0 = not inside a colon definition)
    addi tp, zero, 0

    # Emit PIC prologue for compiled program (25 words, patched at bye):
    # word 0: nop (magic)
    # word 1: lui s5, 0x10000 (UART, absolute hw addr)
    # word 2: auipc t0, <upper20>  (placeholder, patched at bye)
    # word 3: addi  t0, t0, <lower12> (placeholder, patched at bye)
    #   → t0 = here = end of binary (heap pointer variable lives here)
    # word 4: addi s9, t0, 0       (s9 = here, store protection lower bound)
    # word 5: lui t1, 0x04000      (64MB)
    # word 6: add s6, t0, t1       (s6 = here+64MB, stack lower limit)
    # word 7: lui t1, 0x04800      (72MB)
    # word 8: add s4, t0, t1       (s4 = here+72MB, data stack top)
    # word 9: addi s2, s4, 0       (s2 = here+72MB, shadow stack base)
    # word 10: addi s7, s4, 0      (s7 = here+72MB, stack underflow limit)
    # word 11: addi s10, s4, 0     (s10 = here+72MB, shadow underflow limit)
    # word 12: lui t1, 0x04900     (73MB)
    # word 13: add s8, t0, t1      (s8 = here+73MB, shadow upper limit)
    # word 14: addi t1, t0, 1028   (reserve 1 KB pool for `var` slots, then heap)
    # word 15: sw t1, 0(t0)        (mem[here] = t1, init heap pointer)
    # words 16-23: sw a0..a7, 0..28(s6)   (save boot registers in guard zone)
    # word 24: jal x0, +64         (skip 15-instruction error handler)

    # word 0: nop = 0x00000013
    addi t0, zero, 0x13
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 1: lui s5, 0x10000 = 0x10000AB7
    lui t0, 0x10001
    addi t0, t0, -0x549
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 2: auipc x5, 0 (placeholder) = 0x00000297
    addi t0, zero, 0x297
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 3: addi x5, x5, 0 (placeholder) = 0x00028293
    lui t0, 0x00028
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 4: addi s9, t0, 0 (s9 = here) = 0x00028C93
    lui t0, 0x00029
    addi t0, t0, -0x36D
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 5: lui t1, 0x04000 (64MB) = 0x04000337
    lui t0, 0x04000
    addi t0, t0, 0x337
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 6: add s6, t0, t1 (s6 = here+64MB) = 0x00628B33
    lui t0, 0x00629
    addi t0, t0, -0x4CD
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 7: lui t1, 0x04800 (72MB) = 0x04800337
    lui t0, 0x04800
    addi t0, t0, 0x337
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 8: add s4, t0, t1 (s4 = here+72MB) = 0x00628A33
    lui t0, 0x00629
    addi t0, t0, -0x5CD
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 9: addi s2, s4, 0 (s2 = s4) = 0x000A0913
    lui t0, 0x000A1
    addi t0, t0, -0x6ED
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 10: addi s7, s4, 0 (s7 = s4) = 0x000A0B93
    lui t0, 0x000A1
    addi t0, t0, -0x46D
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 11: addi s10, s4, 0 (s10 = s4) = 0x000A0D13
    lui t0, 0x000A1
    addi t0, t0, -0x2ED
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 12: lui t1, 0x04900 (73MB) = 0x04900337
    lui t0, 0x04900
    addi t0, t0, 0x337
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 13: add s8, t0, t1 (s8 = here+73MB) = 0x00628C33
    lui t0, 0x00629
    addi t0, t0, -0x3CD
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 14: addi t1, t0, 1028 (t1 = here+1028, past 1 KB var pool) = 0x40428313
    lui t0, 0x40428
    addi t0, t0, 0x313
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 15: sw t1, 0(t0) (init heap ptr) = 0x0062A023
    lui t0, 0x0062A
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4

    # words 16-23: save boot registers a0-a7 at s6+0..s6+28 (guard zone)
    # sw a0, 0(s6) = 0x00AB2023
    lui t0, 0x00AB2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw a1, 4(s6) = 0x00BB2223
    lui t0, 0x00BB2
    addi t0, t0, 0x223
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw a2, 8(s6) = 0x00CB2423
    lui t0, 0x00CB2
    addi t0, t0, 0x423
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw a3, 12(s6) = 0x00DB2623
    lui t0, 0x00DB2
    addi t0, t0, 0x623
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw a4, 16(s6) = 0x00EB2823
    lui t0, 0x00EB3
    addi t0, t0, -0x7DD
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw a5, 20(s6) = 0x00FB2A23
    lui t0, 0x00FB3
    addi t0, t0, -0x5DD
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw a6, 24(s6) = 0x010B2C23
    lui t0, 0x010B3
    addi t0, t0, -0x3DD
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw a7, 28(s6) = 0x011B2E23
    lui t0, 0x011B3
    addi t0, t0, -0x1DD
    sw t0, 0(s3)
    addi s3, s3, 4

    # word 24: jal x0, +64 (skip 15-instruction error handler) = 0x0400006F
    lui t0, 0x04000
    addi t0, t0, 0x06F
    sw t0, 0(s3)
    addi s3, s3, 4
    # Save error handler output address for runtime check emission
    addi ra, s3, 0
    # --- Runtime error handler: prints "!\n" then halts via QEMU FINISHER ---
    # 1. addi t0, zero, 0x21 = 0x02100293
    lui t0, 0x02100
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # 2. lbu t1, 5(s5) = 0x005AC303
    lui t0, 0x005AC
    addi t0, t0, 0x303
    sw t0, 0(s3)
    addi s3, s3, 4
    # 3. andi t1, t1, 0x20 = 0x02037313
    lui t0, 0x02037
    addi t0, t0, 0x313
    sw t0, 0(s3)
    addi s3, s3, 4
    # 4. beq t1, zero, -8 = 0xFE030CE3
    lui t0, 0xFE031
    addi t0, t0, -0x31D
    sw t0, 0(s3)
    addi s3, s3, 4
    # 5. sb t0, 0(s5) = 0x005A8023
    lui t0, 0x005A8
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # 6. addi t0, zero, 0x0A = 0x00A00293
    lui t0, 0x00A00
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # 7. lbu t1, 5(s5) = 0x005AC303
    lui t0, 0x005AC
    addi t0, t0, 0x303
    sw t0, 0(s3)
    addi s3, s3, 4
    # 8. andi t1, t1, 0x20 = 0x02037313
    lui t0, 0x02037
    addi t0, t0, 0x313
    sw t0, 0(s3)
    addi s3, s3, 4
    # 9. beq t1, zero, -8 = 0xFE030CE3
    lui t0, 0xFE031
    addi t0, t0, -0x31D
    sw t0, 0(s3)
    addi s3, s3, 4
    # 10. sb t0, 0(s5) = 0x005A8023
    lui t0, 0x005A8
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # 11. lui t0, 0x100 = 0x001002B7
    lui t0, 0x00100
    addi t0, t0, 0x2B7
    sw t0, 0(s3)
    addi s3, s3, 4
    # 12. lui t1, 5 = 0x00005337
    lui t0, 0x00005
    addi t0, t0, 0x337
    sw t0, 0(s3)
    addi s3, s3, 4
    # 13. addi t1, t1, 0x555 = 0x55530313
    lui t0, 0x55530
    addi t0, t0, 0x313
    sw t0, 0(s3)
    addi s3, s3, 4
    # 14. sw t1, 0(t0) = 0x0062A023
    lui t0, 0x0062A
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # 15. jal x0, 0 (halt loop) = 0x0000006F
    addi t0, zero, 0x6F
    sw t0, 0(s3)
    addi s3, s3, 4

# ============================================================================
# PHASE 2b: Main compile loop
# ============================================================================
compile_loop:
    # Check output buffer overflow (s3 must be < 0x84100000)
    lui t0, 0x84100
    bltu s3, t0, output_ok
    j error_output_overflow
output_ok:
    # Skip whitespace
skip_ws:
    bne s1, s2, skip_ws_cont    # continue if input remains
    j compile_done              # end of input (needs JAL range)
skip_ws_cont:
    lbu t0, 0(s1)               # peek at current char
    addi t1, zero, 32           # space
    beq t0, t1, skip_char
    addi t1, zero, 10           # newline
    beq t0, t1, skip_char
    addi t1, zero, 13           # CR
    beq t0, t1, skip_char
    addi t1, zero, 9            # tab
    beq t0, t1, skip_char
    j parse_word                # non-whitespace found

skip_char:
    addi t1, zero, 10
    bne t0, t1, skip_char_noline
    addi gp, gp, 1
skip_char_noline:
    addi s1, s1, 1
    j skip_ws

# Parse a word into the word buffer at s6, length in s7
parse_word:
    addi s7, zero, 0            # word length = 0
pw_loop:
    beq s1, s2, pw_done         # end of input?
    lbu t0, 0(s1)               # current char
    addi t1, zero, 32           # space
    beq t0, t1, pw_done
    addi t1, zero, 10           # newline
    beq t0, t1, pw_done
    addi t1, zero, 13           # CR
    beq t0, t1, pw_done
    addi t1, zero, 9            # tab
    beq t0, t1, pw_done
    # check word length limit (31 chars + null = 32 byte dict name field)
    addi t1, zero, 31
    bltu s7, t1, pw_store
    j error_name_overflow
pw_store:
    # store char in word buffer
    add t2, s6, s7              # word_buf[len]
    sb t0, 0(t2)
    addi s7, s7, 1              # len++
    addi s1, s1, 1              # advance input
    j pw_loop
pw_done:
    # null-terminate
    add t2, s6, s7
    sb zero, 0(t2)

# ============================================================================
# Word dispatch: try built-ins, then dictionary, then number
# ============================================================================

    # Check for line comment: backslash
    addi t1, zero, 1
    bne s7, t1, not_backslash   # length must be 1
    lbu t0, 0(s6)
    addi t1, zero, 92           # '\'
    bne t0, t1, not_backslash
    # skip to end of line
skip_line:
    beq s1, s2, compile_loop
    lbu t0, 0(s1)
    addi s1, s1, 1
    addi t1, zero, 10
    bne t0, t1, skip_line
    addi gp, gp, 1
    j compile_loop
not_backslash:

    # Check for paren comment: (
    addi t1, zero, 1
    bne s7, t1, not_paren
    lbu t0, 0(s6)
    addi t1, zero, 40           # '('
    bne t0, t1, not_paren
    # skip to closing )
skip_paren:
    beq s1, s2, compile_loop
    lbu t0, 0(s1)
    addi s1, s1, 1
    addi t1, zero, 10
    bne t0, t1, skip_paren_nonl
    addi gp, gp, 1
skip_paren_nonl:
    addi t1, zero, 41           # ')'
    bne t0, t1, skip_paren
    j compile_loop
not_paren:

    # Check for colon definition
    addi t1, zero, 1
    bne s7, t1, not_colon
    lbu t0, 0(s6)
    addi t1, zero, 58           # ':'
    bne t0, t1, not_colon
    j do_colon
not_colon:

    # Check for semicolon
    addi t1, zero, 1
    bne s7, t1, not_semicolon
    lbu t0, 0(s6)
    addi t1, zero, 59           # ';'
    bne t0, t1, not_semicolon
    j do_semicolon
not_semicolon:

    # --- Check built-in words ---
    # We'll use word length + first bytes for fast dispatch

    # Single-char words (length 1)
    addi t1, zero, 1
    bne s7, t1, not_len1
    lbu t0, 0(s6)

    addi t1, zero, 43          # '+'
    beq t0, t1, emit_plus
    addi t1, zero, 45          # '-'
    beq t0, t1, emit_minus
    addi t1, zero, 64          # '@'
    beq t0, t1, emit_fetch
    addi t1, zero, 33          # '!'
    beq t0, t1, emit_store
    addi t1, zero, 61          # '='
    beq t0, t1, emit_eq
    addi t1, zero, 60          # '<'
    beq t0, t1, emit_lt
    addi t1, zero, 62          # '>'
    beq t0, t1, emit_gt
    addi t1, zero, 105         # 'i'
    bne t0, t1, skip_emit_i
    j emit_i
skip_emit_i:
    addi t1, zero, 106         # 'j'
    bne t0, t1, skip_emit_j
    j emit_j
skip_emit_j:
    addi t1, zero, 42          # '*'
    beq t0, t1, emit_mul
    addi t1, zero, 47          # '/'
    beq t0, t1, emit_div
not_len1:

    # Two-char words (length 2)
    addi t1, zero, 2
    bne s7, t1, not_len2
    lbu t0, 0(s6)
    lbu t3, 1(s6)

    # "if" = 'i','f'
    addi t1, zero, 105         # 'i'
    bne t0, t1, not_if2
    addi t1, zero, 102         # 'f'
    bne t3, t1, not_if2
    j do_if
not_if2:
    # "or" = 'o','r'
    addi t1, zero, 111         # 'o'
    bne t0, t1, not_or2
    addi t1, zero, 114         # 'r'
    beq t3, t1, emit_or
not_or2:
    # "c@" = 'c','@'
    addi t1, zero, 99          # 'c'
    bne t0, t1, not_cfetch
    addi t1, zero, 64          # '@'
    beq t3, t1, emit_cfetch
not_cfetch:
    # "c!" = 'c','!'
    addi t1, zero, 99          # 'c'
    bne t0, t1, not_cstore
    addi t1, zero, 33          # '!'
    beq t3, t1, emit_cstore
not_cstore:
    # "u<" = 'u','<'
    addi t1, zero, 117         # 'u'
    bne t0, t1, not_ult2
    addi t1, zero, 60          # '<'
    beq t3, t1, emit_ult
not_ult2:
    # "do" = 'd','o'
    addi t1, zero, 100         # 'd'
    bne t0, t1, not_do2
    addi t1, zero, 111         # 'o'
    bne t3, t1, not_do2
    j do_do
not_do2:
    # 's"' = 's','"'
    addi t1, zero, 115         # 's'
    bne t0, t1, not_squote2
    addi t1, zero, 34          # '"'
    bne t3, t1, not_squote2
    j do_squote
not_squote2:
    # "w!" = 'w','!'
    addi t1, zero, 119         # 'w'
    bne t0, t1, not_wstore2
    addi t1, zero, 33          # '!'
    beq t3, t1, emit_wstore
not_wstore2:
    # "h!" = 'h','!'
    addi t1, zero, 104         # 'h'
    bne t0, t1, not_hstore2
    addi t1, zero, 33          # '!'
    beq t3, t1, emit_hstore
not_hstore2:
    # "h@" = 'h','@'
    addi t1, zero, 104         # 'h'
    bne t0, t1, not_hfetch2
    addi t1, zero, 64          # '@'
    beq t3, t1, emit_hfetch
not_hfetch2:
    # ">r" = '>','r'
    addi t1, zero, 62          # '>'
    bne t0, t1, not_rto2
    addi t1, zero, 114         # 'r'
    beq t3, t1, emit_rto
not_rto2:
    # "r>" = 'r','>'
    addi t1, zero, 114         # 'r'
    bne t0, t1, not_rfrom2
    addi t1, zero, 62          # '>'
    beq t3, t1, emit_rfrom
not_rfrom2:
    # "r@" = 'r','@'
    addi t1, zero, 114         # 'r'
    bne t0, t1, not_rat2
    addi t1, zero, 64          # '@'
    beq t3, t1, emit_rat
not_rat2:
    j not_len2
not_len2:

    # Three-char words (length 3)
    addi t1, zero, 3
    bne s7, t1, not_len3
    lbu t0, 0(s6)
    lbu t3, 1(s6)
    lbu t4, 2(s6)

    # "dup" = 'd','u','p'
    addi t1, zero, 100         # 'd'
    bne t0, t1, not_dup3
    addi t1, zero, 117         # 'u'
    bne t3, t1, not_dup3
    addi t1, zero, 112         # 'p'
    beq t4, t1, emit_dup
not_dup3:
    # "and" = 'a','n','d'
    addi t1, zero, 97          # 'a'
    bne t0, t1, not_and3
    addi t1, zero, 110         # 'n'
    bne t3, t1, not_and3
    addi t1, zero, 100         # 'd'
    beq t4, t1, emit_and
not_and3:
    # "xor" = 'x','o','r'
    addi t1, zero, 120         # 'x'
    bne t0, t1, not_xor3
    addi t1, zero, 111         # 'o'
    bne t3, t1, not_xor3
    addi t1, zero, 114         # 'r'
    beq t4, t1, emit_xor
not_xor3:
    # "key" = 'k','e','y'
    addi t1, zero, 107         # 'k'
    bne t0, t1, not_key3
    addi t1, zero, 101         # 'e'
    bne t3, t1, not_key3
    addi t1, zero, 121         # 'y'
    bne t4, t1, not_key3
    j emit_key
not_key3:
    # "bye" = 'b','y','e'
    addi t1, zero, 98          # 'b'
    bne t0, t1, not_bye3
    addi t1, zero, 121         # 'y'
    bne t3, t1, not_bye3
    addi t1, zero, 101         # 'e'
    bne t4, t1, not_bye3
    j emit_bye
not_bye3:
    # "rot" = 'r','o','t'
    addi t1, zero, 114         # 'r'
    bne t0, t1, not_rot3
    addi t1, zero, 111         # 'o'
    bne t3, t1, not_rot3
    addi t1, zero, 116         # 't'
    bne t4, t1, not_rot3
    j emit_rot
not_rot3:
    # "mod" = 'm','o','d'
    addi t1, zero, 109         # 'm'
    bne t0, t1, not_mod3
    addi t1, zero, 111         # 'o'
    bne t3, t1, not_mod3
    addi t1, zero, 100         # 'd'
    beq t4, t1, emit_mod
not_mod3:
    # "var" = 'v','a','r'
    addi t1, zero, 118         # 'v'
    bne t0, t1, not_var3
    addi t1, zero, 97          # 'a'
    bne t3, t1, not_var3
    addi t1, zero, 114         # 'r'
    bne t4, t1, not_var3
    j do_var
not_var3:
    j not_len3
not_len3:

    # Four-char words (length 4)
    addi t1, zero, 4
    bne s7, t1, not_len4
    lbu t0, 0(s6)
    lbu t3, 1(s6)
    lbu t4, 2(s6)
    lbu t5, 3(s6)

    # "drop" = 'd','r','o','p'
    addi t1, zero, 100         # 'd'
    bne t0, t1, not_drop4
    addi t1, zero, 114         # 'r'
    bne t3, t1, not_drop4
    addi t1, zero, 111         # 'o'
    bne t4, t1, not_drop4
    addi t1, zero, 112         # 'p'
    beq t5, t1, emit_drop
not_drop4:
    # "swap" = 's','w','a','p'
    addi t1, zero, 115         # 's'
    bne t0, t1, not_swap4
    addi t1, zero, 119         # 'w'
    bne t3, t1, not_swap4
    addi t1, zero, 97          # 'a'
    bne t4, t1, not_swap4
    addi t1, zero, 112         # 'p'
    beq t5, t1, emit_swap
not_swap4:
    # "over" = 'o','v','e','r'
    addi t1, zero, 111         # 'o'
    bne t0, t1, not_over4
    addi t1, zero, 118         # 'v'
    bne t3, t1, not_over4
    addi t1, zero, 101         # 'e'
    bne t4, t1, not_over4
    addi t1, zero, 114         # 'r'
    beq t5, t1, emit_over
not_over4:
    # "then" = 't','h','e','n'
    addi t1, zero, 116         # 't'
    bne t0, t1, not_then4
    addi t1, zero, 104         # 'h'
    bne t3, t1, not_then4
    addi t1, zero, 101         # 'e'
    bne t4, t1, not_then4
    addi t1, zero, 110         # 'n'
    bne t5, t1, not_then4
    j do_then
not_then4:
    # "else" = 'e','l','s','e'
    addi t1, zero, 101         # 'e'
    bne t0, t1, not_else4
    addi t1, zero, 108         # 'l'
    bne t3, t1, not_else4
    addi t1, zero, 115         # 's'
    bne t4, t1, not_else4
    addi t1, zero, 101         # 'e'
    bne t5, t1, not_else4
    j do_else
not_else4:
    # "emit" = 'e','m','i','t'
    addi t1, zero, 101         # 'e'
    bne t0, t1, not_emit4
    addi t1, zero, 109         # 'm'
    bne t3, t1, not_emit4
    addi t1, zero, 105         # 'i'
    bne t4, t1, not_emit4
    addi t1, zero, 116         # 't'
    beq t5, t1, emit_emit
not_emit4:
    # "here" = 'h','e','r','e'
    addi t1, zero, 104         # 'h'
    bne t0, t1, not_here4
    addi t1, zero, 101         # 'e'
    bne t3, t1, not_here4
    addi t1, zero, 114         # 'r'
    bne t4, t1, not_here4
    addi t1, zero, 101         # 'e'
    beq t5, t1, emit_here
not_here4:
    # "exit" = 'e','x','i','t'
    addi t1, zero, 101         # 'e'
    bne t0, t1, not_exit4
    addi t1, zero, 120         # 'x'
    bne t3, t1, not_exit4
    addi t1, zero, 105         # 'i'
    bne t4, t1, not_exit4
    addi t1, zero, 116         # 't'
    bne t5, t1, not_exit4
    j do_exit
not_exit4:
    # "loop" = 'l','o','o','p'
    addi t1, zero, 108         # 'l'
    bne t0, t1, not_loop4
    addi t1, zero, 111         # 'o'
    bne t3, t1, not_loop4
    addi t1, zero, 111         # 'o'
    bne t4, t1, not_loop4
    addi t1, zero, 112         # 'p'
    bne t5, t1, not_loop4
    j do_loop
not_loop4:
    # "__aX" = '_','_','a','0'-'7' (boot registers)
    addi t1, zero, 95          # '_'
    bne t0, t1, not_boot4
    bne t3, t1, not_boot4
    addi t1, zero, 97          # 'a'
    bne t4, t1, not_boot4
    addi t1, zero, 48          # '0'
    blt t5, t1, not_boot4
    addi t1, zero, 56          # '8'
    bge t5, t1, not_boot4
    addi t5, t5, -48           # digit = t5 - '0'
    j emit_boot_reg
not_boot4:
    # "pick" = 'p','i','c','k'
    addi t1, zero, 112         # 'p'
    bne t0, t1, not_pick4
    addi t1, zero, 105         # 'i'
    bne t3, t1, not_pick4
    addi t1, zero, 99          # 'c'
    bne t4, t1, not_pick4
    addi t1, zero, 107         # 'k'
    beq t5, t1, emit_pick
not_pick4:
    j not_len4
not_len4:

    # Five-char words (length 5)
    addi t1, zero, 5
    bne s7, t1, not_len5
    lbu t0, 0(s6)

    # "allot" starts with 'a'
    addi t1, zero, 97          # 'a'
    beq t0, t1, check_allot
    # "begin" starts with 'b'
    addi t1, zero, 98          # 'b'
    beq t0, t1, check_begin
    # "until" starts with 'u'
    addi t1, zero, 117         # 'u'
    beq t0, t1, check_until
    # "while" starts with 'w'
    addi t1, zero, 119         # 'w'
    beq t0, t1, check_while
    # "+loop" starts with '+'
    addi t1, zero, 43          # '+'
    beq t0, t1, check_ploop
    # "leave" starts with 'l'
    addi t1, zero, 108         # 'l'
    beq t0, t1, check_leave
    # "fence" starts with 'f'
    addi t1, zero, 102         # 'f'
    beq t0, t1, check_fence
    j not_len5

check_allot:
    lbu t3, 1(s6)
    addi t1, zero, 108         # 'l'
    bne t3, t1, not_len5
    lbu t3, 2(s6)
    addi t1, zero, 108         # 'l'
    bne t3, t1, not_len5
    lbu t3, 3(s6)
    addi t1, zero, 111         # 'o'
    bne t3, t1, not_len5
    lbu t3, 4(s6)
    addi t1, zero, 116         # 't'
    beq t3, t1, emit_allot
    j not_len5

check_begin:
    lbu t3, 1(s6)
    addi t1, zero, 101         # 'e'
    bne t3, t1, not_len5
    lbu t3, 2(s6)
    addi t1, zero, 103         # 'g'
    bne t3, t1, not_len5
    lbu t3, 3(s6)
    addi t1, zero, 105         # 'i'
    bne t3, t1, not_len5
    lbu t3, 4(s6)
    addi t1, zero, 110         # 'n'
    bne t3, t1, not_begin5
    j do_begin
not_begin5:
    j not_len5

check_until:
    lbu t3, 1(s6)
    addi t1, zero, 110         # 'n'
    bne t3, t1, not_len5
    lbu t3, 2(s6)
    addi t1, zero, 116         # 't'
    bne t3, t1, not_len5
    lbu t3, 3(s6)
    addi t1, zero, 105         # 'i'
    bne t3, t1, not_len5
    lbu t3, 4(s6)
    addi t1, zero, 108         # 'l'
    bne t3, t1, not_until5
    j do_until
not_until5:
    j not_len5

check_while:
    lbu t3, 1(s6)
    addi t1, zero, 104         # 'h'
    bne t3, t1, not_len5
    lbu t3, 2(s6)
    addi t1, zero, 105         # 'i'
    bne t3, t1, not_len5
    lbu t3, 3(s6)
    addi t1, zero, 108         # 'l'
    bne t3, t1, not_len5
    lbu t3, 4(s6)
    addi t1, zero, 101         # 'e'
    bne t3, t1, not_while5
    j do_while
not_while5:
    j not_len5

check_ploop:
    lbu t3, 1(s6)
    addi t1, zero, 108         # 'l'
    bne t3, t1, not_len5
    lbu t3, 2(s6)
    addi t1, zero, 111         # 'o'
    bne t3, t1, not_len5
    lbu t3, 3(s6)
    addi t1, zero, 111         # 'o'
    bne t3, t1, not_len5
    lbu t3, 4(s6)
    addi t1, zero, 112         # 'p'
    bne t3, t1, not_len5
    j do_ploop

check_leave:
    lbu t3, 1(s6)
    addi t1, zero, 101         # 'e'
    bne t3, t1, not_len5
    lbu t3, 2(s6)
    addi t1, zero, 97          # 'a'
    bne t3, t1, not_len5
    lbu t3, 3(s6)
    addi t1, zero, 118         # 'v'
    bne t3, t1, not_len5
    lbu t3, 4(s6)
    addi t1, zero, 101         # 'e'
    bne t3, t1, not_leave
    j do_leave
not_leave:
    j not_len5

check_fence:
    lbu t3, 1(s6)
    addi t1, zero, 101         # 'e'
    bne t3, t1, not_len5
    lbu t3, 2(s6)
    addi t1, zero, 110         # 'n'
    bne t3, t1, not_len5
    lbu t3, 3(s6)
    addi t1, zero, 99          # 'c'
    bne t3, t1, not_len5
    lbu t3, 4(s6)
    addi t1, zero, 101         # 'e'
    beq t3, t1, emit_fence
    j not_len5
not_len5:

    # Six-char words (length 6)
    addi t1, zero, 6
    bne s7, t1, not_len6
    lbu t0, 0(s6)

    # "lshift" starts with 'l'
    addi t1, zero, 108         # 'l'
    beq t0, t1, check_lshift
    # "rshift"/"repeat" start with 'r'
    addi t1, zero, 114         # 'r'
    beq t0, t1, check_r_len6
    # "invert" starts with 'i'
    addi t1, zero, 105         # 'i'
    beq t0, t1, check_invert
    # "negate" starts with 'n'
    addi t1, zero, 110         # 'n'
    beq t0, t1, check_negate
    j not_len6

check_lshift:
    lbu t3, 1(s6)
    addi t1, zero, 115         # 's'
    bne t3, t1, not_len6
    lbu t3, 2(s6)
    addi t1, zero, 104         # 'h'
    bne t3, t1, not_len6
    lbu t3, 3(s6)
    addi t1, zero, 105         # 'i'
    bne t3, t1, not_len6
    lbu t3, 4(s6)
    addi t1, zero, 102         # 'f'
    bne t3, t1, not_len6
    lbu t3, 5(s6)
    addi t1, zero, 116         # 't'
    beq t3, t1, emit_lshift
    j not_len6

check_r_len6:
    lbu t3, 1(s6)
    addi t1, zero, 115         # 's' for rshift
    beq t3, t1, check_rshift_rest
    addi t1, zero, 101         # 'e' for repeat
    beq t3, t1, check_repeat_rest
    j not_len6

check_rshift_rest:
    lbu t3, 2(s6)
    addi t1, zero, 104         # 'h'
    bne t3, t1, not_len6
    lbu t3, 3(s6)
    addi t1, zero, 105         # 'i'
    bne t3, t1, not_len6
    lbu t3, 4(s6)
    addi t1, zero, 102         # 'f'
    bne t3, t1, not_len6
    lbu t3, 5(s6)
    addi t1, zero, 116         # 't'
    beq t3, t1, emit_rshift
    j not_len6

check_repeat_rest:
    lbu t3, 2(s6)
    addi t1, zero, 112         # 'p'
    bne t3, t1, not_len6
    lbu t3, 3(s6)
    addi t1, zero, 101         # 'e'
    bne t3, t1, not_len6
    lbu t3, 4(s6)
    addi t1, zero, 97          # 'a'
    bne t3, t1, not_len6
    lbu t3, 5(s6)
    addi t1, zero, 116         # 't'
    bne t3, t1, not_repeat6
    j do_repeat
not_repeat6:
    j not_len6

check_invert:
    lbu t3, 1(s6)
    addi t1, zero, 110         # 'n'
    bne t3, t1, not_len6
    lbu t3, 2(s6)
    addi t1, zero, 118         # 'v'
    bne t3, t1, not_len6
    lbu t3, 3(s6)
    addi t1, zero, 101         # 'e'
    bne t3, t1, not_len6
    lbu t3, 4(s6)
    addi t1, zero, 114         # 'r'
    bne t3, t1, not_len6
    lbu t3, 5(s6)
    addi t1, zero, 116         # 't'
    beq t3, t1, emit_invert
    j not_len6

check_negate:
    lbu t3, 1(s6)
    addi t1, zero, 101         # 'e'
    bne t3, t1, not_len6
    lbu t3, 2(s6)
    addi t1, zero, 103         # 'g'
    bne t3, t1, not_len6
    lbu t3, 3(s6)
    addi t1, zero, 97          # 'a'
    bne t3, t1, not_len6
    lbu t3, 4(s6)
    addi t1, zero, 116         # 't'
    bne t3, t1, not_len6
    lbu t3, 5(s6)
    addi t1, zero, 101         # 'e'
    beq t3, t1, emit_negate
    j not_len6
not_len6:

    # Eleven-char words (length 11)
    addi t1, zero, 11
    bne s7, t1, not_len11
    # "m-extension" = 'm','-','e','x','t','e','n','s','i','o','n'
    lbu t0, 0(s6)
    addi t1, zero, 109         # 'm'
    bne t0, t1, not_len11
    lbu t0, 1(s6)
    addi t1, zero, 45          # '-'
    bne t0, t1, not_len11
    lbu t0, 2(s6)
    addi t1, zero, 101         # 'e'
    bne t0, t1, not_len11
    lbu t0, 3(s6)
    addi t1, zero, 120         # 'x'
    bne t0, t1, not_len11
    lbu t0, 4(s6)
    addi t1, zero, 116         # 't'
    bne t0, t1, not_len11
    lbu t0, 5(s6)
    addi t1, zero, 101         # 'e'
    bne t0, t1, not_len11
    lbu t0, 6(s6)
    addi t1, zero, 110         # 'n'
    bne t0, t1, not_len11
    lbu t0, 7(s6)
    addi t1, zero, 115         # 's'
    bne t0, t1, not_len11
    lbu t0, 8(s6)
    addi t1, zero, 105         # 'i'
    bne t0, t1, not_len11
    lbu t0, 9(s6)
    addi t1, zero, 111         # 'o'
    bne t0, t1, not_len11
    lbu t0, 10(s6)
    addi t1, zero, 110         # 'n'
    bne t0, t1, not_len11
    addi s0, zero, 1
    j compile_loop
not_len11:

    # --- Dictionary lookup ---
    j dict_lookup

# ============================================================================
# Built-in word code emission
# ============================================================================

# Helper: emit a 32-bit instruction word from t0 into output buffer
emit_instr:
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- dup ---
# addi s4, s4, -4   (push TOS to stack)
# sw   s3, 0(s4)
emit_dup:
    addi a0, zero, 0
    j emit_stk_check
push_dup_cont:
    # addi x20, x20, -4 = 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw s3, 0(s4) — but wait, in compiled code s3=TOS, s4=DSP
    # sw x19, 0(x20) : S-type: imm=0, rs2=x19, rs1=x20, funct3=2, op=0x23
    # imm[11:5]=0, rs2=19, rs1=20, funct3=010, imm[4:0]=0, op=0100011
    # = (0<<25)|(19<<20)|(20<<15)|(2<<12)|(0<<7)|0x23
    # = 0x013A2023
    lui t0, 0x013A2        # 0x013A2000
    addi t0, t0, 0x023     # 0x013A2023
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- drop ---
# lw   s3, 0(s4)
# addi s4, s4, 4
emit_drop:
    addi a0, zero, 11
    j emit_underflow_check
pop_drop_cont:
    # lw x19, 0(x20): I-type: imm=0, rs1=x20, funct3=2, rd=x19, op=0x03
    # = (0<<20)|(20<<15)|(2<<12)|(19<<7)|0x03
    # = 0x000A2983
    lui t0, 0x000A3        # 0x000A3000 (bit11 of 0x983: 1, so lui+1)
    addi t0, t0, -0x67D    # 0x000A3000 - 0x67D = 0x000A2983
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4
    # = (4<<20)|(20<<15)|(0<<12)|(20<<7)|0x13
    # = 0x004A0A13
    lui t0, 0x004A1        # 0x004A1000 (0xA13 bit11=1, so +1)
    addi t0, t0, -0x5ED    # 0x004A1000 - 0x5ED = 0x004A0A13
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- swap ---
# lw   t0, 0(s4)      load second
# sw   s3, 0(s4)      store TOS where second was
# mv   s3, t0         TOS = old second (addi s3, t0, 0)
emit_swap:
    # lw x5, 0(x20): (0<<20)|(20<<15)|(2<<12)|(5<<7)|0x03 = 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x19, 0(x20): 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x19, x5, 0: (0<<20)|(5<<15)|(0<<12)|(19<<7)|0x13 = 0x00028993
    lui t0, 0x00029        # 0x00029000 (0x993 bit11=1, +1)
    addi t0, t0, -0x66D    # 0x00029000 - 0x66D = 0x00028993
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- over ---
# addi s4, s4, -4     make room
# sw   s3, 0(s4)      push TOS
# lw   s3, 4(s4)      TOS = old second (now at offset 4)
emit_over:
    addi a0, zero, 1
    j emit_stk_check
push_over_cont:
    # addi x20, x20, -4: 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x19, 0(x20): 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # lw x19, 4(x20): (4<<20)|(20<<15)|(2<<12)|(19<<7)|0x03 = 0x004A2983
    lui t0, 0x004A3        # bit11 of 983 is set
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- + ---
# lw   t0, 0(s4)      pop second
# addi s4, s4, 4
# add  s3, t0, s3     TOS = second + TOS
emit_plus:
    addi a0, zero, 12
    j emit_underflow_check
pop_plus_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # add x19, x5, x19: R-type (0<<25)|(19<<20)|(5<<15)|(0<<12)|(19<<7)|0x33
    # = 0x013289B3
    lui t0, 0x01329        # bit11 of 9B3 = 1, +1
    addi t0, t0, -0x64D    # 0x01329000 - 0x64D = 0x013289B3
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- - ---
# lw   t0, 0(s4)
# addi s4, s4, 4
# sub  s3, t0, s3     TOS = second - TOS
emit_minus:
    addi a0, zero, 13
    j emit_underflow_check
pop_minus_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sub x19, x5, x19: (0x20<<25)|(19<<20)|(5<<15)|(0<<12)|(19<<7)|0x33
    # = 0x413289B3
    lui t0, 0x41329        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- and ---
# lw   t0, 0(s4)
# addi s4, s4, 4
# and  s3, t0, s3
emit_and:
    addi a0, zero, 14
    j emit_underflow_check
pop_and_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # and x19, x5, x19: (0<<25)|(19<<20)|(5<<15)|(7<<12)|(19<<7)|0x33
    # = 0x0132F9B3
    lui t0, 0x01330        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- or ---
# lw   t0, 0(s4)
# addi s4, s4, 4
# or   s3, t0, s3
emit_or:
    addi a0, zero, 15
    j emit_underflow_check
pop_or_cont:
    # or x19, x5, x19: (0<<25)|(19<<20)|(5<<15)|(6<<12)|(19<<7)|0x33
    # = 0x0132E9B3
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # or: 0x0132E9B3
    lui t0, 0x0132F        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- xor ---
# lw   t0, 0(s4)
# addi s4, s4, 4
# xor  s3, t0, s3
emit_xor:
    addi a0, zero, 16
    j emit_underflow_check
pop_xor_cont:
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # xor x19, x5, x19: (0<<25)|(19<<20)|(5<<15)|(4<<12)|(19<<7)|0x33
    # = 0x0132C9B3
    lui t0, 0x0132D        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- = (equal) ---
# lw   t0, 0(s4)
# addi s4, s4, 4
# sub  t0, t0, s3     t0 = second - TOS (0 if equal)
# seqz s3, t0         s3 = 1 if equal
# neg  s3, s3         s3 = -1 (true) or 0 (false)
emit_eq:
    addi a0, zero, 17
    j emit_underflow_check
pop_eq_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sub x5, x5, x19: (0x20<<25)|(19<<20)|(5<<15)|(0<<12)|(5<<7)|0x33
    # = 0x413282B3
    lui t0, 0x41328
    addi t0, t0, 0x2B3
    sw t0, 0(s3)
    addi s3, s3, 4
    # sltiu x19, x5, 1 (seqz): (1<<20)|(5<<15)|(3<<12)|(19<<7)|0x13
    # = 0x0012B993
    lui t0, 0x0012C        # bit11 of 993=1, +1
    addi t0, t0, -0x66D
    sw t0, 0(s3)
    addi s3, s3, 4
    # sub x19, x0, x19 (neg): (0x20<<25)|(19<<20)|(0<<15)|(0<<12)|(19<<7)|0x33
    # = 0x413009B3
    lui t0, 0x41301        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- < (less than, signed) ---
# lw   t0, 0(s4)
# addi s4, s4, 4
# slt  s3, t0, s3     s3 = 1 if second < TOS
# neg  s3, s3         s3 = -1 or 0
emit_lt:
    addi a0, zero, 18
    j emit_underflow_check
pop_lt_cont:
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # slt x19, x5, x19: (0<<25)|(19<<20)|(5<<15)|(2<<12)|(19<<7)|0x33
    # = 0x0132A9B3
    lui t0, 0x0132B        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    # neg x19, x19: 0x413009B3
    lui t0, 0x41301
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- > (greater than, signed) ---
# lw   t0, 0(s4)
# addi s4, s4, 4
# slt  s3, s3, t0     s3 = 1 if TOS < second (i.e. second > TOS)
# neg  s3, s3
emit_gt:
    addi a0, zero, 19
    j emit_underflow_check
pop_gt_cont:
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # slt x19, x19, x5: (0<<25)|(5<<20)|(19<<15)|(2<<12)|(19<<7)|0x33
    # = 0x0059A9B3
    lui t0, 0x0059B        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    # neg x19, x19: 0x413009B3
    lui t0, 0x41301
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- @ (fetch) ---
# lw   s3, 0(s3)
emit_fetch:
    # lw x19, 0(x19): (0<<20)|(19<<15)|(2<<12)|(19<<7)|0x03
    # = 0x0009A983
    lui t0, 0x0009B        # bit11 of 983=1, +1
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- ! (store) ---
# lw   t0, 0(s4)       n (value to store)
# addi s4, s4, 4
# sw   t0, 0(s3)       store n at address TOS
# lw   s3, 0(s4)       pop new TOS
# addi s4, s4, 4
emit_store:
    addi a0, zero, 20
    j emit_underflow_check
pop_store1_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Store protection check
    addi a0, zero, 34
    j emit_store_check
store_prot1_cont:
    # Heap upper bound check (addr < s6)
    addi a0, zero, 42
    j emit_heap_check
heap_store1_cont:
    # sw x5, 0(x19): 0x0059A023
    lui t0, 0x0059A
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a0, zero, 21
    j emit_underflow_check
pop_store2_cont:
    # lw x19, 0(x20): 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- c@ (char fetch) ---
# lbu  s3, 0(s3)
emit_cfetch:
    # lbu x19, 0(x19): (0<<20)|(19<<15)|(4<<12)|(19<<7)|0x03
    # = 0x0009C983
    lui t0, 0x0009D        # bit11 of 983=1, +1
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- c! (char store) ---
# lw   t0, 0(s4)
# addi s4, s4, 4
# sb   t0, 0(s3)
# lw   s3, 0(s4)
# addi s4, s4, 4
emit_cstore:
    addi a0, zero, 22
    j emit_underflow_check
pop_cstore1_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Store protection check
    addi a0, zero, 35
    j emit_store_check
store_prot2_cont:
    # Heap upper bound check (addr < s6)
    addi a0, zero, 43
    j emit_heap_check
heap_store2_cont:
    # sb x5, 0(x19): 0x00598023
    lui t0, 0x00598
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a0, zero, 23
    j emit_underflow_check
pop_cstore2_cont:
    # lw x19, 0(x20): 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- w! (unchecked 32-bit store, for MMIO) ---
# lw   t0, 0(s4)       value
# addi s4, s4, 4
# sw   t0, 0(s3)       store value at addr (TOS)
# lw   s3, 0(s4)       pop new TOS
# addi s4, s4, 4
emit_wstore:
    addi a0, zero, 49
    j emit_underflow_check
pop_wstore1_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x5, 0(x19): 0x0059A023
    lui t0, 0x0059A
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a0, zero, 50
    j emit_underflow_check
pop_wstore2_cont:
    # lw x19, 0(x20): 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- h! (unchecked 16-bit store, for MMIO) ---
# lw   t0, 0(s4)       value
# addi s4, s4, 4
# sh   t0, 0(s3)       store halfword at addr (TOS)
# lw   s3, 0(s4)       pop new TOS
# addi s4, s4, 4
emit_hstore:
    addi a0, zero, 51
    j emit_underflow_check
pop_hstore1_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sh x5, 0(x19): 0x00599023
    lui t0, 0x00599
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a0, zero, 52
    j emit_underflow_check
pop_hstore2_cont:
    # lw x19, 0(x20): 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- h@ (unsigned 16-bit load) ---
# lhu  s3, 0(s3)
emit_hfetch:
    # lhu x19, 0(x19): 0x0009D983
    lui t0, 0x0009E
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- fence (full memory barrier) ---
emit_fence:
    # fence iorw, iorw: 0x0FF0000F
    lui t0, 0x0FF00
    addi t0, t0, 0xF
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- u< (unsigned less than) ---
# lw   t0, 0(s4)
# addi s4, s4, 4
# sltu s3, t0, s3     s3 = 1 if second <u TOS
# neg  s3, s3         s3 = -1 or 0
emit_ult:
    addi a0, zero, 24
    j emit_underflow_check
pop_ult_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sltu x19, x5, x19: 0x0132B9B3
    lui t0, 0x0132C        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    # neg x19, x19: 0x413009B3
    lui t0, 0x41301        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- lshift (logical shift left) ---
# lw   t0, 0(s4)      pop second (value to shift)
# addi s4, s4, 4
# sll  s3, t0, s3     TOS = second << TOS
emit_lshift:
    addi a0, zero, 25
    j emit_underflow_check
pop_lshift_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sll x19, x5, x19: 0x013299B3
    lui t0, 0x0132A        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- rshift (logical shift right) ---
# lw   t0, 0(s4)
# addi s4, s4, 4
# srl  s3, t0, s3     TOS = second >> TOS (unsigned)
emit_rshift:
    addi a0, zero, 26
    j emit_underflow_check
pop_rshift_cont:
    # lw x5, 0(x20): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # srl x19, x5, x19: 0x0132D9B3
    lui t0, 0x0132E        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- invert (bitwise NOT) ---
# xori s3, s3, -1
emit_invert:
    # xori x19, x19, -1: 0xFFF9C993
    lui t0, 0xFFF9D        # bit11 of 993=1, +1
    addi t0, t0, -0x66D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- negate (arithmetic negate) ---
# sub  s3, x0, s3
emit_negate:
    # sub x19, x0, x19: 0x413009B3
    lui t0, 0x41301        # bit11 of 9B3=1, +1
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- __a0..__a7 (push boot register value) ---
# t5 = digit (0-7). Emits: push TOS, lw s3, -(digit+1)*4(s9)
emit_boot_reg:
    addi a0, zero, 53
    addi a2, t5, 0
    j emit_stk_check
push_boot_cont:
    addi t5, a2, 0
    # addi x20, x20, -4: 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x19, 0(x20): 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # lw x19, offset(x22) where offset = t5*4
    slli t5, t5, 2           # t5 = digit*4
    slli t5, t5, 20          # shift imm to bits [31:20]
    lui t0, 0x000B3
    addi t0, t0, -0x67D      # 0x000B2983 = lw x19, 0(x22)
    or t0, t0, t5            # merge immediate
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- >r (push data TOS onto the return/shadow stack) ---
# sw   s3, 0(s2)       store TOS on shadow stack
# addi s2, s2, 4       advance shadow pointer
# lw   s3, 0(s4)       pop new data TOS
# addi s4, s4, 4
emit_rto:
    addi a0, zero, 54
    j emit_shadow_check
shadow_rto_cont:
    # sw x19, 0(x18): 0x01392023
    lui t0, 0x01392
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x18, x18, 4: 0x00490913
    lui t0, 0x00491
    addi t0, t0, -0x6ED
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a0, zero, 55
    j emit_underflow_check
pop_rto_cont:
    # lw x19, 0(x20): 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- r> (pop the return/shadow stack onto data TOS) ---
# addi s4, s4, -4      make room on data stack
# sw   s3, 0(s4)       push old TOS
# addi s2, s2, -4      retract shadow pointer
# lw   s3, 0(s2)       load new TOS
emit_rfrom:
    addi a0, zero, 56
    j emit_stk_check
push_rfrom_cont:
    # addi x20, x20, -4: 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x19, 0(x20): 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a0, zero, 57
    j emit_shadow_underflow_check
shadow_rfrom_cont:
    # addi x18, x18, -4: 0xFFC90913
    lui t0, 0xFFC91
    addi t0, t0, -0x6ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # lw x19, 0(x18): 0x00092983
    lui t0, 0x00093
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- r@ (peek shadow stack top, leave shadow unchanged) ---
# addi s4, s4, -4      make room on data stack
# sw   s3, 0(s4)       push old TOS
# lw   s3, -4(s2)      read shadow top without popping
emit_rat:
    addi a0, zero, 58
    j emit_stk_check
push_rat_cont:
    # addi x20, x20, -4: 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x19, 0(x20): 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a0, zero, 59
    j emit_shadow_underflow_check
shadow_rat_cont:
    # lw x19, -4(x18): 0xFFC92983
    lui t0, 0xFFC93
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- pick ( xu ... x0 u -- xu ... x0 xu ) ---
# slli t0, s3, 2       t0 = u * 4
# add  t0, s4, t0      t0 = &x_u  (s4 points at x_0; x_u lives at s4+u*4)
# lw   s3, 0(t0)       TOS = x_u
emit_pick:
    addi a0, zero, 60
    j emit_underflow_check
pop_pick_cont:
    # slli x5, x19, 2: funct7=0, shamt=2, rs1=19, funct3=1, rd=5, op=0x13
    # = (0<<25)|(2<<20)|(19<<15)|(1<<12)|(5<<7)|0x13 = 0x00299293
    lui t0, 0x00299
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # add x5, x20, x5: (0<<25)|(5<<20)|(20<<15)|(0<<12)|(5<<7)|0x33 = 0x005A02B3
    lui t0, 0x005A0
    addi t0, t0, 0x2B3
    sw t0, 0(s3)
    addi s3, s3, 4
    # lw x19, 0(x5): 0x0002A983
    lui t0, 0x0002B
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- here (push heap pointer address) ---
# addi s4, s4, -4     push TOS
# sw   s3, 0(s4)
# lui  s3, 0x80100    TOS = 0x80100000
emit_here:
    addi a0, zero, 2
    j emit_stk_check
push_here_cont:
    # addi x20, x20, -4: 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x19, 0(x20): 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x5, x25, 0 (t0 = s9 = heap ptr addr): 0x000C8293
    lui t0, 0x000C8
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # lw x19, 0(x5) (load heap pointer into TOS): 0x0002A983
    lui t0, 0x0002B
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x19, x19, 3 (align step 1): 0x00398993
    lui t0, 0x00399
    addi t0, t0, -0x66D
    sw t0, 0(s3)
    addi s3, s3, 4
    # andi x19, x19, -4 (align step 2): 0xFFC9F993
    lui t0, 0xFFCA0
    addi t0, t0, -0x66D
    sw t0, 0(s3)
    addi s3, s3, 4
    # Heap bounds check (TOS < s6)
    addi a0, zero, 41
    j emit_heap_check
heap_here_cont:
    # sw x19, 0(x5) (store aligned pointer back): 0x0132A023
    lui t0, 0x0132A
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- allot ( n -- ) : advance heap pointer by n bytes ---
emit_allot:
    addi a0, zero, 44
    j emit_underflow_check
pop_allot_cont:
    # addi x5, x25, 0 (t0 = s9 = here addr): 0x000C8293
    lui t0, 0x000C8
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # lw x6, 0(x5) (t1 = current heap ptr): 0x0002A303
    lui t0, 0x0002A
    addi t0, t0, 0x303
    sw t0, 0(s3)
    addi s3, s3, 4
    # add x19, x6, x19 (TOS = new heap ptr): 0x013309B3
    lui t0, 0x01331
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    # Heap bounds check (TOS < s6)
    addi a0, zero, 45
    j emit_heap_check
heap_allot_cont:
    # sw x19, 0(x5) (store new heap ptr): 0x0132A023
    lui t0, 0x0132A
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # lw x19, 0(x20) (pop new TOS): 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4 (advance stack ptr): 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- * (multiply: pop two, push product) ---
# s0 = 0: emit software shift-and-add loop (8 instructions)
# s0 = 1: emit hardware MUL (1 instruction)
emit_mul:
    addi a0, zero, 46
    j emit_underflow_check
pop_mul_cont:
    # lw x5, 0(x20) (pop 2nd): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    bnez s0, emit_mul_hw
    # Software multiply: x19 = x5 * x19
    # addi x6, zero, 0: 0x00000313
    lui t0, 0x00000
    addi t0, t0, 0x313
    sw t0, 0(s3)
    addi s3, s3, 4
    # andi x7, x19, 1: 0x0019F393
    lui t0, 0x0019F
    addi t0, t0, 0x393
    sw t0, 0(s3)
    addi s3, s3, 4
    # beq x7, zero, +8: 0x00038463
    lui t0, 0x00038
    addi t0, t0, 0x463
    sw t0, 0(s3)
    addi s3, s3, 4
    # add x6, x6, x5: 0x00530333
    lui t0, 0x00530
    addi t0, t0, 0x333
    sw t0, 0(s3)
    addi s3, s3, 4
    # slli x5, x5, 1: 0x00129293
    lui t0, 0x00129
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # srli x19, x19, 1: 0x0019D993
    lui t0, 0x0019E
    addi t0, t0, -0x66D
    sw t0, 0(s3)
    addi s3, s3, 4
    # bne x19, zero, -20: 0xFE0996E3
    lui t0, 0xFE099
    addi t0, t0, 0x6E3
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x19, x6, 0: 0x00030993
    lui t0, 0x00031
    addi t0, t0, -0x66D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop
emit_mul_hw:
    # mul x19, x5, x19: 0x033289B3
    lui t0, 0x03329
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- / (divide: pop two, push quotient) ---
# s0 = 0: emit software binary long division (14 instructions)
# s0 = 1: emit hardware DIV (1 instruction)
emit_div:
    addi a0, zero, 47
    j emit_underflow_check
pop_div_cont:
    # lw x5, 0(x20) (pop 2nd): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    bnez s0, emit_div_hw
    j emit_soft_divmod_q
emit_div_hw:
    # div x19, x5, x19: 0x0332C9B3
    lui t0, 0x0332D
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- mod (modulo: pop two, push remainder) ---
# s0 = 0: emit software binary long division returning remainder (14 instructions)
# s0 = 1: emit hardware REM (1 instruction)
emit_mod:
    addi a0, zero, 48
    j emit_underflow_check
pop_mod_cont:
    # lw x5, 0(x20) (pop 2nd): 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    bnez s0, emit_mod_hw
    j emit_soft_divmod_r
emit_mod_hw:
    # rem x19, x5, x19: 0x0332E9B3
    lui t0, 0x0332F
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- Shared software divmod loop (used by / and mod) ---
# Binary long division: x5 = dividend, x19 = divisor
# x6 = remainder, x29 = quotient, x7 = bit counter
emit_soft_divmod_q:
    addi a0, zero, 1           # flag: return quotient
    j emit_soft_divmod
emit_soft_divmod_r:
    addi a0, zero, 0           # flag: return remainder
emit_soft_divmod:
    # --- Sign handling: make both operands positive, save signs ---
    # srai x31, x5, 31 (dividend sign -> x31): 0x41F2DF93
    lui t0, 0x41F2E
    addi t0, t0, -0x6D
    sw t0, 0(s3)
    addi s3, s3, 4
    # srai x30, x19, 31 (divisor sign -> x30): 0x41F9DF13
    lui t0, 0x41F9E
    addi t0, t0, -0xED
    sw t0, 0(s3)
    addi s3, s3, 4
    # xor x5, x5, x31 (flip dividend): 0x01F2C2B3
    lui t0, 0x01F2C
    addi t0, t0, 0x2B3
    sw t0, 0(s3)
    addi s3, s3, 4
    # sub x5, x5, x31 (abs dividend): 0x41F282B3
    lui t0, 0x41F28
    addi t0, t0, 0x2B3
    sw t0, 0(s3)
    addi s3, s3, 4
    # xor x19, x19, x30 (flip divisor): 0x01E9C9B3
    lui t0, 0x01E9D
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    # sub x19, x19, x30 (abs divisor): 0x41E989B3
    lui t0, 0x41E99
    addi t0, t0, -0x64D
    sw t0, 0(s3)
    addi s3, s3, 4
    # xor x30, x31, x30 (quotient sign = dividend ^ divisor): 0x01EFCF33
    lui t0, 0x01EFD
    addi t0, t0, -0xCD
    sw t0, 0(s3)
    addi s3, s3, 4
    # --- Unsigned division on absolute values ---
    # addi x6, zero, 0 (remainder = 0): 0x00000313
    lui t0, 0x00000
    addi t0, t0, 0x313
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x29, zero, 0 (quotient = 0): 0x00000E93
    lui t0, 0x00001
    addi t0, t0, -0x16D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x7, zero, 32 (counter): 0x02000393
    lui t0, 0x02000
    addi t0, t0, 0x393
    sw t0, 0(s3)
    addi s3, s3, 4
    # slli x6, x6, 1: 0x00131313
    lui t0, 0x00131
    addi t0, t0, 0x313
    sw t0, 0(s3)
    addi s3, s3, 4
    # srli x28, x5, 31: 0x01F2DE13
    lui t0, 0x01F2E
    addi t0, t0, -0x1ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # or x6, x6, x28: 0x01C36333
    lui t0, 0x01C36
    addi t0, t0, 0x333
    sw t0, 0(s3)
    addi s3, s3, 4
    # slli x5, x5, 1: 0x00129293
    lui t0, 0x00129
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # slli x29, x29, 1: 0x001E9E93
    lui t0, 0x001EA
    addi t0, t0, -0x16D
    sw t0, 0(s3)
    addi s3, s3, 4
    # bltu x6, x19, +12: 0x01336663
    lui t0, 0x01336
    addi t0, t0, 0x663
    sw t0, 0(s3)
    addi s3, s3, 4
    # sub x6, x6, x19: 0x41330333
    lui t0, 0x41330
    addi t0, t0, 0x333
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x29, x29, 1: 0x001E8E93
    lui t0, 0x001E9
    addi t0, t0, -0x16D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x7, x7, -1: 0xFFF38393
    lui t0, 0xFFF38
    addi t0, t0, 0x393
    sw t0, 0(s3)
    addi s3, s3, 4
    # bne x7, zero, -36: 0xFC039EE3
    lui t0, 0xFC03A
    addi t0, t0, -0x11D
    sw t0, 0(s3)
    addi s3, s3, 4
    # --- Apply sign to result ---
    bnez a0, emit_divmod_quot
    # Remainder: apply dividend sign (x31)
    # xor x6, x6, x31: 0x01F34333
    lui t0, 0x01F34
    addi t0, t0, 0x333
    sw t0, 0(s3)
    addi s3, s3, 4
    # sub x6, x6, x31: 0x41F30333
    lui t0, 0x41F30
    addi t0, t0, 0x333
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x19, x6, 0 (TOS = remainder): 0x00030993
    lui t0, 0x00031
    addi t0, t0, -0x66D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop
emit_divmod_quot:
    # Quotient: apply quotient sign (x30)
    # xor x29, x29, x30: 0x01EECEB3
    lui t0, 0x01EED
    addi t0, t0, -0x14D
    sw t0, 0(s3)
    addi s3, s3, 4
    # sub x29, x29, x30: 0x41EE8EB3
    lui t0, 0x41EE9
    addi t0, t0, -0x14D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x19, x29, 0 (TOS = quotient): 0x000E8993
    lui t0, 0x000E9
    addi t0, t0, -0x66D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- emit (send TOS byte to UART, then drop) ---
# Emits a retry loop:
#   lbu  t0, 5(s5)        check LSR
#   andi t0, t0, 32       THR empty bit
#   beq  t0, zero, -8     retry
#   sb   s3, 0(s5)        send byte
#   lw   s3, 0(s4)        drop (pop new TOS)
#   addi s4, s4, 4
emit_emit:
    # lbu x5, 5(x21): (5<<20)|(21<<15)|(4<<12)|(5<<7)|0x03 = 0x005AC283
    lui t0, 0x005AC
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # andi x5, x5, 32: (32<<20)|(5<<15)|(7<<12)|(5<<7)|0x13 = 0x0202F293
    lui t0, 0x0202F
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # beq x5, x0, -8: B-type offset=-8, rs1=x5, rs2=x0, funct3=0
    # offset=-8: bits [12|10:5|4:1|11]
    # -8 in 13-bit signed = 1_111111_1100_1 (0x1FF8)
    # b12=1, b10:5=111111, b4:1=1100, b11=1
    # = (1<<31)|(0x3F<<25)|(0<<20)|(5<<15)|(0<<12)|(0x18<<7)|(1<<7)|0x63
    # Let me compute: offset = -8 = 0xFFF8 (13-bit)
    # b12 = bit12 = 1
    # b11 = bit11 = 1
    # b10:5 = bits 10..5 = 111111 = 0x3F
    # b4:1 = bits 4..1 = 1100 = 0xC
    # encoding: [b12][b10:5] | [rs2] | [rs1] | [funct3] | [b4:1][b11] | [opcode]
    # = [1][111111] | [00000] | [00101] | [000] | [1100][1] | [1100011]
    # = 1111111_00000_00101_000_11001_1100011
    # = FE000CE3
    lui t0, 0xFE029        # beq x5, x0, -8 = 0xFE028CE3
    addi t0, t0, -0x31D    # 0xFE029000 - 0x31D = 0xFE028CE3
    sw t0, 0(s3)
    addi s3, s3, 4
    # sb x19, 0(x21): S-type imm=0, rs2=x19, rs1=x21, funct3=0, op=0x23
    # = (0<<25)|(19<<20)|(21<<15)|(0<<12)|(0<<7)|0x23
    # = 0x013A8023
    lui t0, 0x013A8
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a0, zero, 27
    j emit_underflow_check
pop_emit_cont:
    # lw x19, 0(x20): 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x20, x20, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- key (read byte from UART, push onto stack) ---
# Emits:
#   addi s4, s4, -4     push TOS
#   sw   s3, 0(s4)
#   lbu  t0, 5(s5)      check LSR
#   andi t0, t0, 1      data ready?
#   beq  t0, zero, -8   retry
#   lbu  s3, 0(s5)      read byte into TOS
emit_key:
    addi a0, zero, 3
    j emit_stk_check
push_key_cont:
    # addi x20, x20, -4: 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x19, 0(x20): 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # lbu x5, 5(x21): 0x005AC283
    lui t0, 0x005AC
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # andi x5, x5, 1: (1<<20)|(5<<15)|(7<<12)|(5<<7)|0x13 = 0x0012F293
    lui t0, 0x0012F
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # beq x5, x0, -8: 0xFE000CE3 (same as emit's retry)
    lui t0, 0xFE001
    addi t0, t0, -0x31D
    sw t0, 0(s3)
    addi s3, s3, 4
    # lbu x19, 0(x21): (0<<20)|(21<<15)|(4<<12)|(19<<7)|0x03 = 0x000AC983
    lui t0, 0x000AD        # bit11 of 983=1, +1
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- rot ( a b c -- b c a ) ---
# lw   t0, 0(s4)       t0 = b
# lw   t1, 4(s4)       t1 = a
# sw   s3, 4(s4)       stack[1] = c (old TOS)
# sw   t0, 0(s4)       stack[0] = b -- wait, that's wrong
# Actually: ( a b c -- b c a )
# Before: s3=c, 0(s4)=b, 4(s4)=a
# After:  s3=a, 0(s4)=c, 4(s4)=b
emit_rot:
    # lw x5, 0(x20): 0x000A2283  (t0 = b)
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # lw x6, 4(x20): (4<<20)|(20<<15)|(2<<12)|(6<<7)|0x03 = 0x004A2303
    lui t0, 0x004A2
    addi t0, t0, 0x303
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x19, 0(x20): 0x013A2023  (stack[0] = c)
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x5, 4(x20): S-type imm=4, rs2=x5, rs1=x20, funct3=2, op=0x23
    # imm=4: hi=0, lo=4
    # = (0<<25)|(5<<20)|(20<<15)|(2<<12)|(4<<7)|0x23
    # = 0x005A2223
    lui t0, 0x005A2
    addi t0, t0, 0x223
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x19, x6, 0 (mv s3, t1): 0x00030993
    lui t0, 0x00031        # bit11 of 993=1, +1
    addi t0, t0, -0x66D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- bye (QEMU shutdown) ---
# Emits:
#   lui  s5, 0x100        QEMU test device address
#   lui  t0, 0x5          FINISHER_PASS upper
#   addi t0, t0, 0x555    FINISHER_PASS lower
#   sw   t0, 0(s5)        trigger poweroff
emit_bye:
    # bye is allowed anywhere (including inside colon definitions).
    # Any unclosed definition or unbalanced control structure will still
    # be caught by the end-of-input finalization path.
    # lui x21, 0x100 = (0x100 << 12) | (21 << 7) | 0x37 = 0x00100AB7
    lui t0, 0x00101        # bit11 of AB7=1, +1
    addi t0, t0, -0x549
    sw t0, 0(s3)
    addi s3, s3, 4
    # lui x5, 0x5 = (0x5 << 12) | (5 << 7) | 0x37 = 0x000052B7
    lui t0, 0x00005
    addi t0, t0, 0x2B7
    sw t0, 0(s3)
    addi s3, s3, 4
    # addi x5, x5, 0x555 = (0x555<<20)|(5<<15)|(0<<12)|(5<<7)|0x13
    # = 0x55528293
    lui t0, 0x55528
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x5, 0(x21) = (0<<25)|(5<<20)|(21<<15)|(2<<12)|(0<<7)|0x23
    # = 0x005AA023
    lui t0, 0x005AA
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# ============================================================================
# Control structures
# ============================================================================

# --- IF ---
# Emit: consume TOS flag, branch-if-zero forward (patch later)
# Push current output address onto control stack for THEN/ELSE to patch
do_if:
    addi a0, zero, 28
    j emit_underflow_check
pop_if_cont:
    # Emit: addi t0, s3, 0 (mv t0, TOS) : 0x00098293
    lui t0, 0x00098
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: lw s3, 0(s4) (pop new TOS): 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: addi s4, s4, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: beq t0, zero, 0 (placeholder, patched later): 0x00028063
    # beq x5, x0, 0: B-type offset=0
    lui t0, 0x00028
    addi t0, t0, 0x063
    sw t0, 0(s3)
    # Push address of this beq onto control stack (for patching)
    lui t1, 0x82801
    addi t1, t1, 0x100
    bltu s9, t1, cstk_ok1
    j error_cstk_overflow
cstk_ok1:
    sw s3, 0(s9)
    addi s9, s9, 4
    addi s3, s3, 4
    j compile_loop

# --- THEN ---
# Patch the forward branch from IF or ELSE to point here
do_then:
    # Pop control stack, skipping leave markers (odd = leave, even = if-addr)
    lui t4, 0x82801
    addi t4, t4, 0x100
    addi t6, zero, 0
then_skip_leaves:
    lui t1, 0x82800
    addi t1, t1, 0x100
    bne s9, t1, cstk_uok1
    j error_cstk_underflow
cstk_uok1:
    addi s9, s9, -4
    lw t2, 0(s9)
    andi t1, t2, 1
    beqz t1, then_got_if
    slli t1, t6, 2
    add t1, t4, t1
    sw t2, 0(t1)
    addi t6, t6, 1
    j then_skip_leaves
then_got_if:
    # Re-push leave markers back onto control stack
    beqz t6, then_no_repush
    addi t5, zero, 0
then_repush:
    lui t1, 0x82801
    addi t1, t1, 0x100
    bltu s9, t1, cstk_ok2
    j error_cstk_overflow
cstk_ok2:
    slli t1, t5, 2
    add t1, t4, t1
    lw t0, 0(t1)
    sw t0, 0(s9)
    addi s9, s9, 4
    addi t5, t5, 1
    bne t5, t6, then_repush
then_no_repush:
    # t2 = address of beq/jal to patch
    # Compute offset: current output pos - patch address
    sub t3, s3, t2           # offset in bytes
    # Load the instruction at t2
    lw t4, 0(t2)
    # Determine if it's a beq (opcode 0x63) or jal (opcode 0x6F)
    andi t5, t4, 0x7F       # extract opcode
    addi t6, zero, 0x6F     # JAL opcode
    beq t5, t6, patch_jal
    # It's a branch - re-encode with correct offset
    # B-type: encode t3 as branch offset
    # We need to rebuild the instruction with the new offset
    # Keep rs1, rs2, funct3 from original; replace offset bits
    # Original beq t0, zero: rs1=x5, rs2=x0, funct3=0
    # New instruction: beq x5, x0, offset=t3
    # Build B-type encoding from scratch
    # b12 = (t3>>12)&1, b11=(t3>>11)&1, b10:5=(t3>>5)&0x3F, b4:1=(t3>>1)&0xF
    srli t5, t3, 12         # b12
    andi t5, t5, 1
    slli t5, t5, 31         # position bit 31

    srli t6, t3, 5          # b10:5
    andi t6, t6, 0x3F
    slli t6, t6, 25         # position bits 30:25
    or t5, t5, t6

    # rs2=0 (bits 24:20) = 0, rs1=5 (bits 19:15), funct3=0 (bits 14:12)
    # rs1=5: 5<<15 = 0x28000
    lui t6, 0x00028         # 0x28000 (actually 0x00028000)
    or t5, t5, t6

    # b4:1 and b11
    srli t6, t3, 1          # b4:1
    andi t6, t6, 0xF
    slli t6, t6, 8          # position bits 11:8
    or t5, t5, t6

    srli t6, t3, 11         # b11
    andi t6, t6, 1
    slli t6, t6, 7          # position bit 7
    or t5, t5, t6

    addi t6, zero, 0x63     # opcode
    or t5, t5, t6
    sw t5, 0(t2)            # patch!
    j compile_loop

patch_jal:
    # Re-encode as JAL x0, offset=t3
    # J-type: b20=(t3>>20)&1, b10:1=(t3>>1)&0x3FF, b11=(t3>>11)&1, b19:12=(t3>>12)&0xFF
    srli t5, t3, 20
    andi t5, t5, 1
    slli t5, t5, 31         # bit 31

    srli t6, t3, 1
    andi t6, t6, 0x3FF
    slli t6, t6, 21         # bits 30:21
    or t5, t5, t6

    srli t6, t3, 11
    andi t6, t6, 1
    slli t6, t6, 20         # bit 20
    or t5, t5, t6

    srli t6, t3, 12
    andi t6, t6, 0xFF
    slli t6, t6, 12         # bits 19:12
    or t5, t5, t6

    addi t6, zero, 0x6F     # JAL opcode
    or t5, t5, t6
    # rd=x0 (bits 11:7 = 0), already 0
    sw t5, 0(t2)
    j compile_loop

# --- ELSE ---
# Emit unconditional jump forward (patch later by THEN)
# Patch the IF's branch to jump here (just past the jal)
do_else:
    # Pop control stack, skipping leave markers
    lui t4, 0x82801
    addi t4, t4, 0x100
    addi t6, zero, 0
else_skip_leaves:
    lui t1, 0x82800
    addi t1, t1, 0x100
    bne s9, t1, cstk_uok2
    j error_cstk_underflow
cstk_uok2:
    addi s9, s9, -4
    lw t2, 0(s9)
    andi t1, t2, 1
    beqz t1, else_got_if
    slli t1, t6, 2
    add t1, t4, t1
    sw t2, 0(t1)
    addi t6, t6, 1
    j else_skip_leaves
else_got_if:
    # t2 = if-addr. Re-push leave markers.
    beqz t6, else_no_repush
    addi t5, zero, 0
else_repush:
    lui t1, 0x82801
    addi t1, t1, 0x100
    bltu s9, t1, cstk_ok3
    j error_cstk_overflow
cstk_ok3:
    slli t1, t5, 2
    add t1, t4, t1
    lw t0, 0(t1)
    sw t0, 0(s9)
    addi s9, s9, 4
    addi t5, t5, 1
    bne t5, t6, else_repush
else_no_repush:
    # Emit: jal zero, 0 (placeholder for jump over else-body)
    addi t0, zero, 0x6F
    sw t0, 0(s3)
    addi t6, s3, 0          # t6 = address of new jal
    addi s3, s3, 4

    # Patch IF's branch to point here (current s3, after the jal)
    sub t3, s3, t2           # offset from IF's beq to here
    # Rebuild beq with new offset (same logic as do_then for branch)
    srli t5, t3, 12
    andi t5, t5, 1
    slli t5, t5, 31

    srli t4, t3, 5
    andi t4, t4, 0x3F
    slli t4, t4, 25
    or t5, t5, t4

    lui t4, 0x00028
    or t5, t5, t4

    srli t4, t3, 1
    andi t4, t4, 0xF
    slli t4, t4, 8
    or t5, t5, t4

    srli t4, t3, 11
    andi t4, t4, 1
    slli t4, t4, 7
    or t5, t5, t4

    addi t4, zero, 0x63
    or t5, t5, t4
    sw t5, 0(t2)

    # Push the jal address for THEN to patch
    lui t1, 0x82801
    addi t1, t1, 0x100
    bltu s9, t1, cstk_ok4
    j error_cstk_overflow
cstk_ok4:
    sw t6, 0(s9)
    addi s9, s9, 4
    j compile_loop

# --- BEGIN ---
# Push current output address onto control stack (backward target)
do_begin:
    lui t0, 0x82801
    addi t0, t0, 0x100
    bltu s9, t0, cstk_ok5
    j error_cstk_overflow
cstk_ok5:
    sw s3, 0(s9)
    addi s9, s9, 4
    j compile_loop

# --- UNTIL ---
# Pop flag, branch back to BEGIN if zero
do_until:
    addi a0, zero, 29
    j emit_underflow_check
pop_until_cont:
    # Emit: mv t0, s3 (addi t0, s3, 0): 0x00098293
    lui t0, 0x00098
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: lw s3, 0(s4): 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: addi s4, s4, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Pop BEGIN address from control stack
    lui t1, 0x82800
    addi t1, t1, 0x100
    bne s9, t1, cstk_uok3
    j error_cstk_underflow
cstk_uok3:
    addi s9, s9, -4
    lw t2, 0(s9)
    # Compute backward offset: BEGIN_addr - current_pos
    sub t3, t2, s3           # negative offset (backward)
    # Emit: beq t0, zero, offset (branch back if flag was 0/false)
    # Build B-type: beq x5, x0, t3
    srli t5, t3, 12
    andi t5, t5, 1
    slli t5, t5, 31

    srli t6, t3, 5
    andi t6, t6, 0x3F
    slli t6, t6, 25
    or t5, t5, t6

    lui t6, 0x00028
    or t5, t5, t6

    srli t6, t3, 1
    andi t6, t6, 0xF
    slli t6, t6, 8
    or t5, t5, t6

    srli t6, t3, 11
    andi t6, t6, 1
    slli t6, t6, 7
    or t5, t5, t6

    addi t6, zero, 0x63
    or t5, t5, t6
    sw t5, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- exit (early return from word) ---
# Same return sequence as semicolon: pop shadow stack, load ID, jal dispatch
do_exit:
    # Shadow underflow check before pop
    addi a0, zero, 37
    j emit_shadow_underflow_check
shadow_exit_cont:
    # Emit: addi x18, x18, -4 = 0xFFC90913
    lui t0, 0xFFC91
    addi t0, t0, -0x6ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: lw x9, 0(x18) = 0x00092483
    lui t0, 0x00092
    addi t0, t0, 0x483
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: jal x0, 0 (placeholder for dispatch)
    addi t0, zero, 0x6F
    sw t0, 0(s3)
    lui t1, 0x82850
    bltu s11, t1, patch_ok1
    j error_patch_overflow
patch_ok1:
    sw s3, 0(s11)
    addi s11, s11, 4
    addi s3, s3, 4
    j compile_loop

# --- while (begin ... cond while ... repeat) ---
# Same as if: consume TOS, branch-if-zero forward, push beq addr
do_while:
    addi a0, zero, 30
    j emit_underflow_check
pop_while_cont:
    # Emit: addi t0, s3, 0 (mv t0, TOS): 0x00098293
    lui t0, 0x00098
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: lw s3, 0(s4): 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: addi s4, s4, 4: 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: beq t0, zero, 0 (placeholder): 0x00028063
    lui t0, 0x00028
    addi t0, t0, 0x063
    sw t0, 0(s3)
    lui t1, 0x82801
    addi t1, t1, 0x100
    bltu s9, t1, cstk_ok6
    j error_cstk_overflow
cstk_ok6:
    sw s3, 0(s9)
    addi s9, s9, 4
    addi s3, s3, 4
    j compile_loop

# --- repeat (end of begin/while loop) ---
# Pop while's beq addr, pop begin addr, emit jal back to begin, patch while's beq
do_repeat:
    # Pop while's beq address
    lui t1, 0x82800
    addi t1, t1, 0x100
    bne s9, t1, cstk_uok4a
    j error_cstk_underflow
cstk_uok4a:
    addi s9, s9, -4
    lw t2, 0(s9)
    # Pop begin address
    bne s9, t1, cstk_uok4b
    j error_cstk_underflow
cstk_uok4b:
    addi s9, s9, -4
    lw t4, 0(s9)

    # Emit: jal x0, <back to begin>
    sub t3, t4, s3
    # Encode J-type
    srli t5, t3, 20
    andi t5, t5, 1
    slli t5, t5, 31

    srli t6, t3, 1
    andi t6, t6, 0x3FF
    slli t6, t6, 21
    or t5, t5, t6

    srli t6, t3, 11
    andi t6, t6, 1
    slli t6, t6, 20
    or t5, t5, t6

    srli t6, t3, 12
    andi t6, t6, 0xFF
    slli t6, t6, 12
    or t5, t5, t6

    addi t6, zero, 0x6F
    or t5, t5, t6
    sw t5, 0(s3)
    addi s3, s3, 4

    # Patch while's beq to point here
    sub t3, s3, t2
    srli t5, t3, 12
    andi t5, t5, 1
    slli t5, t5, 31

    srli t6, t3, 5
    andi t6, t6, 0x3F
    slli t6, t6, 25
    or t5, t5, t6

    lui t6, 0x00028
    or t5, t5, t6

    srli t6, t3, 1
    andi t6, t6, 0xF
    slli t6, t6, 8
    or t5, t5, t6

    srli t6, t3, 11
    andi t6, t6, 1
    slli t6, t6, 7
    or t5, t5, t6

    addi t6, zero, 0x63
    or t5, t5, t6
    sw t5, 0(t2)
    j compile_loop

# --- do (counted loop start: limit index do ... loop) ---
# Move TOS (index) and second (limit) to shadow stack, push loop start
do_do:
    # Emit: sw x19, 0(x18) — store index at s2
    # = 0x01392023
    lui t0, 0x01392
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a0, zero, 31
    j emit_underflow_check
pop_do1_cont:
    # Emit: lw x5, 0(x20) — load limit
    # = 0x000A2283
    lui t0, 0x000A2
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: addi x20, x20, 4 — pop data stack
    # = 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: sw x5, 4(x18) — store limit at s2+4
    # = 0x00592223
    lui t0, 0x00592
    addi t0, t0, 0x223
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: addi x18, x18, 8 — advance shadow stack
    # = 0x00890913
    lui t0, 0x00891
    addi t0, t0, -0x6ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Shadow stack overflow check for DO loop
    addi a0, zero, 10
    j emit_shadow_check
shadow_do_cont:
    addi a0, zero, 32
    j emit_underflow_check
pop_do2_cont:
    # Emit: lw x19, 0(x20) — pop new TOS
    # = 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: addi x20, x20, 4 — pop data stack
    # = 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Pre-test: load start and limit from shadow, skip loop if start >= limit.
    # Emit: lw x5, -8(x18) — load start = 0xFF892283
    lui t0, 0xFF892
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: lw x6, -4(x18) — load limit = 0xFFC92303
    lui t0, 0xFFC92
    addi t0, t0, 0x303
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: bgeu x5, x6, 0 — placeholder, patched by `loop` = 0x0062F063
    lui t0, 0x0062F
    addi t0, t0, 0x63
    sw t0, 0(s3)
    # Push bgeu address (current s3) onto control stack — patched in `loop`.
    # Pushed BEFORE body-start so `loop_pop_cs` finds body-start first.
    lui t0, 0x82801
    addi t0, t0, 0x100
    bltu s9, t0, cstk_ok7a
    j error_cstk_overflow
cstk_ok7a:
    sw s3, 0(s9)
    addi s9, s9, 4
    addi s3, s3, 4
    # Push loop body start onto control stack
    lui t0, 0x82801
    addi t0, t0, 0x100
    bltu s9, t0, cstk_ok7
    j error_cstk_overflow
cstk_ok7:
    sw s3, 0(s9)
    addi s9, s9, 4
    j compile_loop

# --- loop (counted loop end: increment index, branch if not done) ---
do_loop:
    # Pop control stack entries: skip leave markers (odd), find do-body addr (even)
    lui t4, 0x82801
    addi t4, t4, 0x100          # scratch area for leave addrs (0x82801100)
    addi t6, zero, 0            # leave count
loop_pop_cs:
    lui t1, 0x82800
    addi t1, t1, 0x100
    bne s9, t1, cstk_uok5
    j error_cstk_underflow
cstk_uok5:
    addi s9, s9, -4
    lw t2, 0(s9)
    andi t1, t2, 1              # check if odd (leave marker)
    beqz t1, loop_got_body      # even = do-body address
    # It's a leave marker — store stripped address
    andi t2, t2, -2             # clear bit 0
    slli t1, t6, 2
    add t1, t4, t1
    sw t2, 0(t1)               # save leave jal address
    addi t6, t6, 1
    j loop_pop_cs
loop_got_body:
    # t2 = do-body start. Pop one more cstk entry = pre-test bgeu skip_addr.
    lui t1, 0x82800
    addi t1, t1, 0x100
    bne s9, t1, cstk_uok5b
    j error_cstk_underflow
cstk_uok5b:
    addi s9, s9, -4
    lw t0, 0(s9)
    # Save skip_addr at 0x82801200 (loop scratch) for later patching
    lui t1, 0x82801
    sw t0, 0x200(t1)
    # t2 = do-body start address, t6 = leave count, t4 = leave addr array
    # Emit: lw x5, -8(x18) — load index = 0xFF892283
    lui t0, 0xFF892
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: addi x5, x5, 1 — increment = 0x00128293
    lui t0, 0x00128
    addi t0, t0, 0x293
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: lw x6, -4(x18) — load limit = 0xFFC92303
    lui t0, 0xFFC92
    addi t0, t0, 0x303
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: beq x5, x6, +12 — skip to loop exit = 0x00628663
    lui t0, 0x00628
    addi t0, t0, 0x663
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: sw x5, -8(x18) — store updated index = 0xFE592C23
    lui t0, 0xFE593
    addi t0, t0, -0x3DD
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: jal x0, <back to loop body>
    sub t3, t2, s3
    # Encode J-type
    srli t5, t3, 20
    andi t5, t5, 1
    slli t5, t5, 31

    srli t0, t3, 1
    andi t0, t0, 0x3FF
    slli t0, t0, 21
    or t5, t5, t0

    srli t0, t3, 11
    andi t0, t0, 1
    slli t0, t0, 20
    or t5, t5, t0

    srli t0, t3, 12
    andi t0, t0, 0xFF
    slli t0, t0, 12
    or t5, t5, t0

    addi t0, zero, 0x6F
    or t5, t5, t0
    sw t5, 0(s3)
    addi s3, s3, 4
    # Patch pre-test bgeu to jump here (skip_target = current s3 = shadow-check entry).
    lui t0, 0x82801
    lw t1, 0x200(t0)           # t1 = skip_addr (loop scratch)
    sub t3, s3, t1             # offset = skip_target - skip_addr
    # Encode B-type bgeu t0, t1, offset
    srli t0, t3, 12
    andi t0, t0, 1
    slli t0, t0, 31
    srli t2, t3, 5
    andi t2, t2, 0x3F
    slli t2, t2, 25
    or t0, t0, t2
    srli t2, t3, 1
    andi t2, t2, 0xF
    slli t2, t2, 8
    or t0, t0, t2
    srli t2, t3, 11
    andi t2, t2, 1
    slli t2, t2, 7
    or t0, t0, t2
    lui t2, 0x0062F
    addi t2, t2, 0x63
    or t0, t0, t2
    sw t0, 0(t1)
    # Shadow underflow check before popping loop params
    addi a2, t4, 0
    addi a3, t6, 0
    addi a0, zero, 38
    j emit_shadow_underflow_check
shadow_loop_cont:
    addi t4, a2, 0
    addi t6, a3, 0
    # Emit: addi x18, x18, -8 — pop loop params = 0xFF890913
    lui t0, 0xFF891
    addi t0, t0, -0x6ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Now patch all leave jals to jump here (past the cleanup)
    beqz t6, loop_no_leaves
    addi t5, zero, 0           # leave index
loop_patch_leaves:
    slli t1, t5, 2
    add t1, t4, t1
    lw t2, 0(t1)               # leave jal address
    sub t3, s3, t2             # offset = here - leave_addr
    # Encode J-type: jal x0, t3
    srli t0, t3, 20
    andi t0, t0, 1
    slli t0, t0, 31

    srli t1, t3, 1
    andi t1, t1, 0x3FF
    slli t1, t1, 21
    or t0, t0, t1

    srli t1, t3, 11
    andi t1, t1, 1
    slli t1, t1, 20
    or t0, t0, t1

    srli t1, t3, 12
    andi t1, t1, 0xFF
    slli t1, t1, 12
    or t0, t0, t1

    addi t1, zero, 0x6F
    or t0, t0, t1
    sw t0, 0(t2)               # patch leave's jal

    addi t5, t5, 1
    bne t5, t6, loop_patch_leaves
loop_no_leaves:
    j compile_loop

# --- i (push loop index onto data stack) ---
emit_i:
    addi a0, zero, 4
    j emit_stk_check
push_i_cont:
    # Emit: addi x20, x20, -4 = 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: sw x19, 0(x20) = 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: lw x19, -8(x18) = 0xFF892983
    lui t0, 0xFF893
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- j (push outer loop index onto data stack) ---
emit_j:
    addi a0, zero, 5
    j emit_stk_check
push_j_cont:
    # Emit: addi x20, x20, -4 = 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: sw x19, 0(x20) = 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: lw x19, -16(x18) = 0xFF092983
    # I-type: imm=-16=0xFF0, rs1=18, funct3=010, rd=19
    # = (0xFF0<<20)|(18<<15)|(2<<12)|(19<<7)|0x03 = 0xFF092983
    lui t0, 0xFF093        # bit11 of 983=1, +1
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# --- +loop (variable-increment counted loop end) ---
# TOS is the increment. Add to index, check if crossed limit boundary.
# For positive increment: loop while index < limit
# For negative increment: loop while index >= limit
# Simplified: always use positive increment semantics (add TOS to index, compare)
do_ploop:
    # Pop control stack entries: skip leave markers (odd), find do-body addr (even)
    lui t4, 0x82801
    addi t4, t4, 0x100          # scratch area for leave addrs (0x82801100)
    addi t6, zero, 0            # leave count
ploop_pop_cs:
    lui t1, 0x82800
    addi t1, t1, 0x100
    bne s9, t1, cstk_uok6
    j error_cstk_underflow
cstk_uok6:
    addi s9, s9, -4
    lw t2, 0(s9)
    andi t1, t2, 1
    beqz t1, ploop_got_body
    andi t2, t2, -2             # clear bit 0
    slli t1, t6, 2
    add t1, t4, t1
    sw t2, 0(t1)
    addi t6, t6, 1
    j ploop_pop_cs
ploop_got_body:
    # t2 = do-body start. Pop one more cstk entry = pre-test bgeu skip_addr.
    lui t1, 0x82800
    addi t1, t1, 0x100
    bne s9, t1, cstk_uok6b
    j error_cstk_underflow
cstk_uok6b:
    addi s9, s9, -4
    lw t0, 0(s9)
    lui t1, 0x82801
    sw t0, 0x200(t1)
    # t2 = do-body start address, t6 = leave count, t4 = leave addr array
    # Emit: lw x5, -8(x18) — load index = 0xFF892283
    lui t0, 0xFF892
    addi t0, t0, 0x283
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: add x5, x5, x19 — add increment (TOS) to index = 0x013282B3
    lui t0, 0x01328
    addi t0, t0, 0x2B3
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: lw x6, -4(x18) — load limit = 0xFFC92303
    lui t0, 0xFFC92
    addi t0, t0, 0x303
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a2, t4, 0
    addi a3, t6, 0
    addi a0, zero, 33
    j emit_underflow_check
pop_ploop_cont:
    addi t4, a2, 0
    addi t6, a3, 0
    # Emit: lw x19, 0(x20) — pop new TOS (consume increment) = 0x000A2983
    lui t0, 0x000A3
    addi t0, t0, -0x67D
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: addi x20, x20, 4 = 0x004A0A13
    lui t0, 0x004A1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: beq x5, x6, +12 — if index==limit, exit loop = 0x00628663
    lui t0, 0x00628
    addi t0, t0, 0x663
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: sw x5, -8(x18) — store updated index = 0xFE592C23
    lui t0, 0xFE593
    addi t0, t0, -0x3DD
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: jal x0, <back to loop body>
    sub t3, t2, s3
    srli t5, t3, 20
    andi t5, t5, 1
    slli t5, t5, 31

    srli t0, t3, 1
    andi t0, t0, 0x3FF
    slli t0, t0, 21
    or t5, t5, t0

    srli t0, t3, 11
    andi t0, t0, 1
    slli t0, t0, 20
    or t5, t5, t0

    srli t0, t3, 12
    andi t0, t0, 0xFF
    slli t0, t0, 12
    or t5, t5, t0

    addi t0, zero, 0x6F
    or t5, t5, t0
    sw t5, 0(s3)
    addi s3, s3, 4
    # Patch pre-test bgeu to jump here.
    lui t0, 0x82801
    lw t1, 0x200(t0)
    sub t3, s3, t1
    srli t0, t3, 12
    andi t0, t0, 1
    slli t0, t0, 31
    srli t2, t3, 5
    andi t2, t2, 0x3F
    slli t2, t2, 25
    or t0, t0, t2
    srli t2, t3, 1
    andi t2, t2, 0xF
    slli t2, t2, 8
    or t0, t0, t2
    srli t2, t3, 11
    andi t2, t2, 1
    slli t2, t2, 7
    or t0, t0, t2
    lui t2, 0x0062F
    addi t2, t2, 0x63
    or t0, t0, t2
    sw t0, 0(t1)
    # Shadow underflow check before popping loop params
    addi a2, t4, 0
    addi a3, t6, 0
    addi a0, zero, 39
    j emit_shadow_underflow_check
shadow_ploop_cont:
    addi t4, a2, 0
    addi t6, a3, 0
    # Emit: addi x18, x18, -8 — pop loop params = 0xFF890913
    lui t0, 0xFF891
    addi t0, t0, -0x6ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Patch leave jals to jump here (past cleanup)
    beqz t6, ploop_no_leaves
    addi t5, zero, 0
ploop_patch_leaves:
    slli t1, t5, 2
    add t1, t4, t1
    lw t2, 0(t1)
    sub t3, s3, t2
    srli t0, t3, 20
    andi t0, t0, 1
    slli t0, t0, 31

    srli t1, t3, 1
    andi t1, t1, 0x3FF
    slli t1, t1, 21
    or t0, t0, t1

    srli t1, t3, 11
    andi t1, t1, 1
    slli t1, t1, 20
    or t0, t0, t1

    srli t1, t3, 12
    andi t1, t1, 0xFF
    slli t1, t1, 12
    or t0, t0, t1

    addi t1, zero, 0x6F
    or t0, t0, t1
    sw t0, 0(t2)

    addi t5, t5, 1
    bne t5, t6, ploop_patch_leaves
ploop_no_leaves:
    j compile_loop

# --- leave (early exit from do/loop) ---
# Emit: cleanup loop params + forward jump (patched by loop/+loop)
# We emit the cleanup (addi x18, x18, -8) then a forward jal placeholder.
# The jal gets pushed onto control stack; loop/+loop patches it when it
# processes the loop end. To make this work, we use a second control stack
# entry that loop recognizes.
# Simplified approach: leave emits jal x0, 0 placeholder and pushes its
# address onto a separate "leave list" that loop patches. But we only have
# one control stack. Instead, we'll push a sentinel: leave pushes the jal
# address, then loop patches all leave jals after emitting its own code.
#
# Simplest: leave emits addi x18, x18, -8 + jal x0, 0, pushes jal addr
# onto control stack. But this conflicts with the do address already there.
#
# Better: leave puts its patch address in the patch list (s11) just like
# semicolon's dispatch jumps. But those get patched to dispatch, not to
# loop-exit. We need a different mechanism.
#
# Practical approach: leave emits the forward jal and stores its address
# in the control stack ABOVE the do-body address. loop will pop past any
# leave entries until it finds the do-body address. We mark leave entries
# by storing them as (addr | 1) — odd values are leave patches, even values
# are loop targets.
do_leave:
    # Shadow underflow check before popping loop params
    addi a0, zero, 40
    j emit_shadow_underflow_check
shadow_leave_cont:
    # Emit: addi x18, x18, -8 — pop loop params from shadow stack
    # = 0xFF890913
    lui t0, 0xFF891
    addi t0, t0, -0x6ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: jal x0, 0 — forward jump placeholder (patched by loop)
    addi t0, zero, 0x6F
    sw t0, 0(s3)
    # Push (address | 1) onto control stack to mark as leave
    lui t1, 0x82801
    addi t1, t1, 0x100
    bltu s9, t1, cstk_ok8
    j error_cstk_overflow
cstk_ok8:
    ori t0, s3, 1
    sw t0, 0(s9)
    addi s9, s9, 4
    addi s3, s3, 4
    j compile_loop

# --- s" (string literal) ---
# Parse characters until closing ", embed in code with skip-over jump.
# At runtime: pushes (addr, len) onto data stack.
do_squote:
    # Skip one whitespace char after s"
    addi s1, s1, 1
    # Emit: jal x0, 0 — skip over string data (patched later)
    addi t0, zero, 0x6F
    sw t0, 0(s3)
    addi t4, s3, 0              # t4 = address of skip jal (for patching)
    addi s3, s3, 4
    # t2 = string start address in output
    addi t2, s3, 0
    # Copy chars until '"'
sq_copy:
    beq s1, s2, error_word      # unterminated string literal
    lbu t0, 0(s1)
    addi s1, s1, 1
    addi t1, zero, 34           # '"'
    beq t0, t1, sq_done
    sb t0, 0(s3)
    addi s3, s3, 1
    j sq_copy
sq_done:
    # t3 = string length
    sub t3, s3, t2
    # Pad output to 4-byte alignment
sq_align:
    andi t0, s3, 3
    beqz t0, sq_aligned
    sb zero, 0(s3)
    addi s3, s3, 1
    j sq_align
sq_aligned:
    # Patch the skip jal to jump here
    sub t5, s3, t4              # offset = current - jal_addr
    # Encode J-type: jal x0, t5
    srli t0, t5, 20
    andi t0, t0, 1
    slli t0, t0, 31

    srli t6, t5, 1
    andi t6, t6, 0x3FF
    slli t6, t6, 21
    or t0, t0, t6

    srli t6, t5, 11
    andi t6, t6, 1
    slli t6, t6, 20
    or t0, t0, t6

    srli t6, t5, 12
    andi t6, t6, 0xFF
    slli t6, t6, 12
    or t0, t0, t6

    addi t6, zero, 0x6F
    or t0, t0, t6
    sw t0, 0(t4)                # patch skip jal

    # Emit code to push (addr, len) onto data stack
    addi a0, zero, 6
    j emit_stk_check
push_sq1_cont:
    # addi x20, x20, -4 (make room): 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw x19, 0(x20) (save old TOS): 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4
    addi a0, zero, 7
    j emit_stk_check
push_sq2_cont:
    # addi x20, x20, -4 (make room for addr): 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4

    # Compute PC-relative offset from auipc position to string data.
    # t2 = string start in output buffer, s3 = where auipc will be emitted.
    sub t5, t2, s3              # offset = string_pos - auipc_pos (negative)

    # Split t5 into upper20 + lower12 (signed)
    slli t6, t5, 20
    srli t6, t6, 20             # t6 = lower 12 bits
    srai t0, t5, 12             # upper 20 (arithmetic shift for sign)
    srli t1, t6, 11
    andi t1, t1, 1
    add t0, t0, t1              # adjust upper if bit11 of lower is set

    # Emit: auipc x19, upper20
    slli t0, t0, 12
    addi t1, zero, 19
    slli t1, t1, 7
    ori t1, t1, 0x17            # auipc opcode
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: addi x19, x19, lower12
    slli t0, t6, 20
    lui t1, 0x99
    addi t1, t1, -0x66D         # 0x98993
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4

    # sw x19, 0(x20) — store string address: 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4

    # Now load length into TOS
    # t3 still has string length. Emit: addi x19, x0, t3
    # This assumes length fits in 12-bit signed (max 2047). Strings > 2047 bytes
    # would need lui+addi but that's an unrealistic case for embedded.
    slli t0, t3, 20
    addi t1, zero, 19
    slli t1, t1, 7
    ori t1, t1, 0x13
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# ============================================================================
# Colon definition and semicolon
# ============================================================================

# : (colon) — start a new word definition
# Parse the next word (the name), create a dictionary entry pointing to
# the current output position.
do_colon:
    # Check for nested colon definition
    beqz tp, colon_ok
    j error_nested_colon
colon_ok:
    addi tp, zero, 1            # set inside-definition flag
    # Skip whitespace to get the name
    j skip_ws_colon
skip_ws_colon:
    beq s1, s2, error_word      # colon at EOF
    lbu t0, 0(s1)
    addi t1, zero, 32
    beq t0, t1, skip_colon_ws
    addi t1, zero, 10
    beq t0, t1, skip_colon_ws
    addi t1, zero, 9
    beq t0, t1, skip_colon_ws
    addi t1, zero, 13
    beq t0, t1, skip_colon_ws
    j read_colon_name
skip_colon_ws:
    addi s1, s1, 1
    j skip_ws_colon

read_colon_name:
    # Read name into dictionary entry directly
    # s4 points to next free dictionary slot (36 bytes: 32 name + 4 addr)
    addi t2, zero, 0           # name length counter
rcn_loop:
    beq s1, s2, rcn_done
    lbu t0, 0(s1)
    addi t1, zero, 32
    beq t0, t1, rcn_done
    addi t1, zero, 10
    beq t0, t1, rcn_done
    addi t1, zero, 9
    beq t0, t1, rcn_done
    addi t1, zero, 13
    beq t0, t1, rcn_done
    # store in dictionary name field
    add t3, s4, t2
    sb t0, 0(t3)
    addi t2, t2, 1
    addi s1, s1, 1
    j rcn_loop
rcn_done:
    # null-terminate name
    add t3, s4, t2
    sb zero, 0(t3)
    # Emit forward jump over word body (placeholder, patched by semicolon)
    # jal x0, 0 (placeholder)
    addi t0, zero, 0x6F
    sw t0, 0(s3)
    # Push this jal's address onto control stack for ; to patch
    lui t1, 0x82801
    addi t1, t1, 0x100
    bltu s9, t1, cstk_ok9
    j error_cstk_overflow
cstk_ok9:
    sw s3, 0(s9)
    addi s9, s9, 4
    addi s3, s3, 4
    # Store current output position (after the jal) as body address
    sw s3, 32(s4)
    # Advance dictionary pointer by 36 (check dictionary limit: 0x82800000)
    addi s4, s4, 36
    lui t0, 0x82800
    bltu s4, t0, dict_ok
    j error_dict_overflow
dict_ok:
    j compile_loop

# ; (semicolon) — end a word definition
# Emit the return sequence: pop shadow stack, jal dispatch
do_semicolon:
    # Check for semicolon outside definition
    bnez tp, semi_ok
    j error_semi_outside
semi_ok:
    addi tp, zero, 0            # clear inside-definition flag
    # Shadow underflow check before pop
    addi a0, zero, 36
    j emit_shadow_underflow_check
shadow_semi_cont:
    # Emit: addi s2, s2, -4 (pop shadow stack)
    # addi x18, x18, -4 = 0xFFC90913
    lui t0, 0xFFC91
    addi t0, t0, -0x6ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: lw s1, 0(s2) (load return ID)
    # lw x9, 0(x18) = 0x00092483
    lui t0, 0x00092
    addi t0, t0, 0x483
    sw t0, 0(s3)
    addi s3, s3, 4
    # Emit: jal zero, dispatch (placeholder — address TBD, add to patch list)
    addi t0, zero, 0x6F     # jal x0, 0 (placeholder)
    sw t0, 0(s3)
    # Record this location in the patch list
    lui t1, 0x82850
    bltu s11, t1, patch_ok2
    j error_patch_overflow
patch_ok2:
    sw s3, 0(s11)
    addi s11, s11, 4
    addi s3, s3, 4
    # Patch the forward jump from colon (skip over body)
    # Pop control stack to get the jal address
    addi s9, s9, -4
    lw t2, 0(s9)            # t2 = address of the colon's forward jal
    sub t3, s3, t2           # offset = current pos - jal pos
    # Encode as J-type: jal x0, t3
    srli t5, t3, 20
    andi t5, t5, 1
    slli t5, t5, 31

    srli t6, t3, 1
    andi t6, t6, 0x3FF
    slli t6, t6, 21
    or t5, t5, t6

    srli t6, t3, 11
    andi t6, t6, 1
    slli t6, t6, 20
    or t5, t5, t6

    srli t6, t3, 12
    andi t6, t6, 0xFF
    slli t6, t6, 12
    or t5, t5, t6

    addi t6, zero, 0x6F
    or t5, t5, t6
    sw t5, 0(t2)            # patch the colon's forward jump
    j compile_loop

# ============================================================================
# var (variable: heap-backed named cell)
# ============================================================================
# Each `var NAME` assigns the next slot in the 1 KB variable pool reserved
# by the prologue at here+4..here+1028. Body pushes slot address via
# `addi x19, x25, offset` — one instruction, no inline storage, no
# hardcoded address. `NAME !` / `NAME @` work exactly like a C `int *` slot.
#
# The compile-time slot counter lives at 0x82900000 (u32, zero-init).
do_var:
    beqz tp, var_ok
    j error_nested_colon
var_ok:
    j skip_ws_var
skip_ws_var:
    beq s1, s2, error_word
    lbu t0, 0(s1)
    addi t1, zero, 32
    beq t0, t1, skip_var_ws
    addi t1, zero, 10
    beq t0, t1, skip_var_ws
    addi t1, zero, 9
    beq t0, t1, skip_var_ws
    addi t1, zero, 13
    beq t0, t1, skip_var_ws
    j read_var_name
skip_var_ws:
    addi s1, s1, 1
    j skip_ws_var

read_var_name:
    addi t2, zero, 0
rvn_loop:
    beq s1, s2, rvn_done
    lbu t0, 0(s1)
    addi t1, zero, 32
    beq t0, t1, rvn_done
    addi t1, zero, 10
    beq t0, t1, rvn_done
    addi t1, zero, 9
    beq t0, t1, rvn_done
    addi t1, zero, 13
    beq t0, t1, rvn_done
    add t3, s4, t2
    sb t0, 0(t3)
    addi t2, t2, 1
    addi s1, s1, 1
    j rvn_loop
rvn_done:
    add t3, s4, t2
    sb zero, 0(t3)

    # Load compile-time slot counter from 0x82900000
    lui t5, 0x82900
    lw t6, 0(t5)
    # Overflow check: counter must be < 256 (pool has 256 slots)
    addi t0, zero, 0x100
    bltu t6, t0, var_slot_ok
    j error_dict_overflow
var_slot_ok:
    # Compute slot offset: 4 + counter * 4
    slli t0, t6, 2
    addi t0, t0, 4
    # Increment counter
    addi t6, t6, 1
    sw t6, 0(t5)

    # Emit forward-jump over body: jal x0, +28 = 0x01C0006F
    lui t1, 0x01C00
    addi t1, t1, 0x06F
    sw t1, 0(s3)
    addi s3, s3, 4

    # Store body_addr in dict[32]
    sw s3, 32(s4)

    # Emit body (6 instructions, 24 bytes):
    # 1. addi x20, x20, -4 = 0xFFCA0A13 (push data stack ptr)
    lui t1, 0xFFCA1
    addi t1, t1, -0x5ED
    sw t1, 0(s3)
    addi s3, s3, 4
    # 2. sw x19, 0(x20) = 0x013A2023 (save old TOS)
    lui t1, 0x013A2
    addi t1, t1, 0x023
    sw t1, 0(s3)
    addi s3, s3, 4
    # 3. addi x19, x25, offset = (offset << 20) | 0x000C8993
    slli t1, t0, 20
    lui t2, 0x000C9
    addi t2, t2, -0x66D
    or t1, t1, t2
    sw t1, 0(s3)
    addi s3, s3, 4
    # 4. addi x18, x18, -4 = 0xFFC90913 (pop shadow stack)
    lui t1, 0xFFC91
    addi t1, t1, -0x6ED
    sw t1, 0(s3)
    addi s3, s3, 4
    # 5. lw x9, 0(x18) = 0x00092483 (load return ID)
    lui t1, 0x00092
    addi t1, t1, 0x483
    sw t1, 0(s3)
    addi s3, s3, 4
    # 6. jal x0, dispatch (placeholder, added to patch list)
    addi t1, zero, 0x6F
    sw t1, 0(s3)
    lui t2, 0x82850
    bltu s11, t2, patch_ok_var
    j error_patch_overflow
patch_ok_var:
    sw s3, 0(s11)
    addi s11, s11, 4
    addi s3, s3, 4

    # Advance dict pointer
    addi s4, s4, 36
    lui t0, 0x82800
    bltu s4, t0, dict_ok_var
    j error_dict_overflow
dict_ok_var:
    j compile_loop

# ============================================================================
# Dictionary lookup (user-defined words)
# ============================================================================
dict_lookup:
    # Scan dictionary from start (0x82000000) to s4
    # Each entry: 32 bytes name + 4 bytes address
    lui t2, 0x82000          # dictionary base
dl_loop:
    beq t2, s4, try_number   # searched all entries, not found
    # Compare word buffer (s6, len s7) against entry name at t2
    addi t3, zero, 0         # comparison index
dl_cmp:
    add t4, s6, t3           # &word_buf[i]
    lbu t4, 0(t4)            # word_buf[i]
    add t5, t2, t3           # &entry_name[i]
    lbu t5, 0(t5)            # entry_name[i]
    bne t4, t5, dl_next      # mismatch
    beqz t4, dl_found        # both null = match
    addi t3, t3, 1
    addi t6, zero, 31
    bltu t3, t6, dl_cmp      # keep comparing (max 31 chars)
    j dl_next                # too long, skip

dl_found:
    # Emit a call to this word
    # 1. li s1, <call_site_id>  — set return ID FIRST
    # 2. sw s1, 0(s2)          — push it to shadow stack
    # 3. addi s2, s2, 4        — bump shadow stack
    # 4. jal zero, <word_addr> — jump to word

    # Get word address from dictionary entry
    lw t6, 32(t2)           # word body address in output

    # Emit: addi x9, x0, <s10> (li s1, call_site_id)
    # = (s10 << 20) | (0<<15) | (0<<12) | (9<<7) | 0x13
    slli t0, s10, 20
    addi t4, zero, 0x13
    ori t4, t4, 0x480       # (9<<7) = 0x480
    or t0, t0, t4
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: sw x9, 0(x18) = 0x00992023
    lui t0, 0x00992
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: addi x18, x18, 4 = 0x00490913
    lui t0, 0x00491
    addi t0, t0, -0x6ED
    sw t0, 0(s3)
    addi s3, s3, 4

    # Shadow stack overflow check
    addi a2, t6, 0
    addi a0, zero, 9
    j emit_shadow_check
shadow_call_cont:
    addi t6, a2, 0

    # Record call site: store current output address + dispatch ID
    # The call site address (where execution resumes after return) is s3+4
    # (after the jal we're about to emit)
    # Store in call site list for dispatch table generation
    lui t4, 0x82850         # call site list base: 0x82850000
    slli t5, s10, 2         # offset = id * 4
    add t4, t4, t5
    addi t5, s3, 4          # call site address = after the jal
    sw t5, 0(t4)            # store in list

    # Emit: jal x0, offset (to word body)
    # offset = word_addr - current_output_pos
    sub t4, t6, s3          # offset = target - here
    # Encode J-type: jal x0, t4
    srli t5, t4, 20
    andi t5, t5, 1
    slli t5, t5, 31         # bit 31 (b20)

    srli t0, t4, 1
    andi t0, t0, 0x3FF
    slli t0, t0, 21         # bits 30:21 (b10:1)
    or t5, t5, t0

    srli t0, t4, 11
    andi t0, t0, 1
    slli t0, t0, 20         # bit 20 (b11)
    or t5, t5, t0

    srli t0, t4, 12
    andi t0, t0, 0xFF
    slli t0, t0, 12         # bits 19:12 (b19:12)
    or t5, t5, t0

    addi t0, zero, 0x6F     # JAL opcode, rd=x0
    or t5, t5, t0
    sw t5, 0(s3)
    addi s3, s3, 4

    # Increment dispatch ID (check call site limit: 65536 = 0x10000)
    lui t0, 0x10
    bltu s10, t0, call_ok
    j error_call_overflow
call_ok:
    addi s10, s10, 1
    j compile_loop

dl_next:
    addi t2, t2, 36          # next dictionary entry
    j dl_loop

# ============================================================================
# Number parsing (decimal, with optional leading -)
# ============================================================================
try_number:
    addi t2, zero, 0         # accumulator
    addi t3, zero, 0         # index into word
    addi t4, zero, 0         # negative flag

    # Check for leading '-'
    lbu t0, 0(s6)
    addi t1, zero, 45        # '-'
    bne t0, t1, num_loop
    addi t4, zero, 1         # set negative flag
    addi t3, t3, 1           # skip '-'

num_loop:
    add t5, s6, t3
    lbu t0, 0(t5)
    beqz t0, num_done        # null terminator = end of word

    # Check if digit: '0' <= t0 <= '9'
    addi t0, t0, -48         # normalize '0' to 0
    addi t1, zero, 10
    bgeu t0, t1, error_word  # not a digit = error

    # accumulator = accumulator * 10 + digit
    # Multiply by 10 without MUL: t2 = t2*8 + t2*2 = (t2<<3) + (t2<<1)
    slli t5, t2, 3
    slli t6, t2, 1
    add t2, t5, t6
    add t2, t2, t0           # + digit

    addi t3, t3, 1
    j num_loop

num_done:
    # If nothing was parsed (length=0, or only '-'), it's an error
    beqz t3, error_word
    addi t1, zero, 1
    beq t3, t1, check_neg_only  # if len=1, was it just '-'?
    j apply_neg
check_neg_only:
    bnez t4, error_word      # if negative flag set and only 1 char, error
apply_neg:
    beqz t4, emit_literal    # not negative
    sub t2, zero, t2         # negate

emit_literal:
    addi a0, zero, 8
    j emit_stk_check
push_lit_cont:
    # addi s4, s4, -4: 0xFFCA0A13
    lui t0, 0xFFCA1
    addi t0, t0, -0x5ED
    sw t0, 0(s3)
    addi s3, s3, 4
    # sw s3, 0(s4): 0x013A2023
    lui t0, 0x013A2
    addi t0, t0, 0x023
    sw t0, 0(s3)
    addi s3, s3, 4

    # Load the number into s3 (TOS)
    # If it fits in 12-bit signed (-2048..2047): addi s3, zero, N
    # Otherwise: lui s3, upper; addi s3, s3, lower
    # Check if -2048 <= t2 <= 2047
    addi t1, zero, 2047
    blt t1, t2, big_literal  # t2 > 2047
    addi t1, zero, -2048
    blt t2, t1, big_literal  # t2 < -2048

    # Small literal: emit addi x19, x0, t2
    # = (t2 << 20) | (0<<15) | (0<<12) | (19<<7) | 0x13 = (t2<<20) | 0x993
    slli t0, t2, 20
    addi t1, zero, 19
    slli t1, t1, 7           # t1 = 0x980
    ori t1, t1, 0x13         # t1 = 0x993
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

big_literal:
    # Need lui + addi
    # Compute upper20 and lower12
    # If lower12 bit 11 is set, add 1 to upper (sign extension compensation)
    slli t5, t2, 20          # isolate lower 12 bits
    srli t5, t5, 20          # t5 = t2 & 0xFFF
    srli t6, t2, 12          # upper 20 bits (logical shift)
    # Check if bit 11 of lower is set
    srli t1, t5, 11
    andi t1, t1, 1
    add t6, t6, t1           # adjust upper if needed

    # Emit: lui x19, t6
    # = (t6 << 12) | (19 << 7) | 0x37 = (t6<<12) | 0x9B7
    slli t0, t6, 12
    addi t1, zero, 19
    slli t1, t1, 7           # t1 = 0x980
    ori t1, t1, 0x37         # t1 = 0x9B7
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: addi x19, x19, lower12
    # = (t5 << 20) | (19<<15) | (0<<12) | (19<<7) | 0x13 = (t5<<20) | 0x98993
    slli t0, t5, 20
    lui t1, 0x99
    addi t1, t1, -0x66D     # t1 = 0x98993
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4
    j compile_loop

# ============================================================================
# Shared runtime check emitter
# Emits: bltu <check>, +8 ; jal x0, <offset_to_error_handler>
# Uses: t0, t4, t5, t6, a0, a1 (preserves t2, t3, ra)
# ra = error handler output address
# a0 = dispatch return ID
# ============================================================================
emit_shadow_underflow_check:
    lui a1, 0x012D6
    addi a1, a1, 0x463
    j emit_rt_check
emit_heap_check:
    lui a1, 0x0169E
    addi a1, a1, 0x463
    j emit_rt_check
emit_underflow_check:
    lui a1, 0x017A6
    addi a1, a1, 0x463
    j emit_rt_check
emit_store_check:
    lui a1, 0x0199F
    addi a1, a1, 0x463
    j emit_rt_check
emit_stk_check:
    lui a1, 0x014B6
    addi a1, a1, 0x463
    j emit_rt_check
emit_shadow_check:
    lui a1, 0x01896
    addi a1, a1, 0x463
emit_rt_check:
    sw a1, 0(s3)
    addi s3, s3, 4
    sub t4, ra, s3
    srli t5, t4, 20
    andi t5, t5, 1
    slli t5, t5, 31
    srli t6, t4, 1
    andi t6, t6, 0x3FF
    slli t6, t6, 21
    or t5, t5, t6
    srli t6, t4, 11
    andi t6, t6, 1
    slli t6, t6, 20
    or t5, t5, t6
    srli t6, t4, 12
    andi t6, t6, 0xFF
    slli t6, t6, 12
    or t5, t5, t6
    addi t6, zero, 0x6F
    or t5, t5, t6
    sw t5, 0(s3)
    addi s3, s3, 4
    beqz a0, rtc0
    addi a0, a0, -1
    beqz a0, rtc1
    addi a0, a0, -1
    beqz a0, rtc2
    addi a0, a0, -1
    beqz a0, rtc3
    addi a0, a0, -1
    beqz a0, rtc4
    addi a0, a0, -1
    beqz a0, rtc5
    addi a0, a0, -1
    beqz a0, rtc6
    addi a0, a0, -1
    beqz a0, rtc7
    addi a0, a0, -1
    beqz a0, rtc8
    addi a0, a0, -1
    beqz a0, rtc9
    addi a0, a0, -1
    beqz a0, rtc10
    addi a0, a0, -1
    beqz a0, rtc11
    addi a0, a0, -1
    beqz a0, rtc12
    addi a0, a0, -1
    beqz a0, rtc13
    addi a0, a0, -1
    beqz a0, rtc14
    addi a0, a0, -1
    beqz a0, rtc15
    addi a0, a0, -1
    beqz a0, rtc16
    addi a0, a0, -1
    beqz a0, rtc17
    addi a0, a0, -1
    beqz a0, rtc18
    addi a0, a0, -1
    beqz a0, rtc19
    addi a0, a0, -1
    beqz a0, rtc20
    addi a0, a0, -1
    beqz a0, rtc21
    addi a0, a0, -1
    beqz a0, rtc22
    addi a0, a0, -1
    beqz a0, rtc23
    addi a0, a0, -1
    beqz a0, rtc24
    addi a0, a0, -1
    beqz a0, rtc25
    addi a0, a0, -1
    beqz a0, rtc26
    addi a0, a0, -1
    beqz a0, rtc27
    addi a0, a0, -1
    beqz a0, rtc28
    addi a0, a0, -1
    beqz a0, rtc29
    addi a0, a0, -1
    beqz a0, rtc30
    addi a0, a0, -1
    beqz a0, rtc31
    addi a0, a0, -1
    beqz a0, rtc32
    addi a0, a0, -1
    beqz a0, rtc33
    addi a0, a0, -1
    beqz a0, rtc34
    addi a0, a0, -1
    beqz a0, rtc35
    addi a0, a0, -1
    beqz a0, rtc36
    addi a0, a0, -1
    beqz a0, rtc37
    addi a0, a0, -1
    beqz a0, rtc38
    addi a0, a0, -1
    beqz a0, rtc39
    addi a0, a0, -1
    beqz a0, rtc40
    addi a0, a0, -1
    beqz a0, rtc41
    addi a0, a0, -1
    beqz a0, rtc42
    addi a0, a0, -1
    beqz a0, rtc43
    addi a0, a0, -1
    beqz a0, rtc44
    addi a0, a0, -1
    beqz a0, rtc45
    addi a0, a0, -1
    beqz a0, rtc46
    addi a0, a0, -1
    beqz a0, rtc47
    addi a0, a0, -1
    beqz a0, rtc48
    addi a0, a0, -1
    beqz a0, rtc49
    addi a0, a0, -1
    beqz a0, rtc50
    addi a0, a0, -1
    beqz a0, rtc51
    addi a0, a0, -1
    beqz a0, rtc52
    addi a0, a0, -1
    beqz a0, rtc53
    addi a0, a0, -1
    beqz a0, rtc54
    addi a0, a0, -1
    beqz a0, rtc55
    addi a0, a0, -1
    beqz a0, rtc56
    addi a0, a0, -1
    beqz a0, rtc57
    addi a0, a0, -1
    beqz a0, rtc58
    addi a0, a0, -1
    beqz a0, rtc59
    addi a0, a0, -1
    beqz a0, rtc60
    j error_word
rtc0:
    j push_dup_cont
rtc1:
    j push_over_cont
rtc2:
    j push_here_cont
rtc3:
    j push_key_cont
rtc4:
    j push_i_cont
