rtc56:
    j push_rfrom_cont
rtc57:
    j shadow_rfrom_cont
rtc58:
    j push_rat_cont
rtc59:
    j shadow_rat_cont
rtc60:
    j pop_pick_cont

# ============================================================================
# Error handlers: write error name to word buffer, then fall through/jump to error_word
# ============================================================================
error_name_overflow:
    addi t0, zero, 110        # 'n'
    sb t0, 0(s6)
    addi t0, zero, 97         # 'a'
    sb t0, 1(s6)
    addi t0, zero, 109        # 'm'
    sb t0, 2(s6)
    addi t0, zero, 101        # 'e'
    sb t0, 3(s6)
    sb zero, 4(s6)
    j error_word

error_cstk_overflow:
    addi t0, zero, 99         # 'c'
    sb t0, 0(s6)
    addi t0, zero, 115        # 's'
    sb t0, 1(s6)
    addi t0, zero, 116        # 't'
    sb t0, 2(s6)
    addi t0, zero, 107        # 'k'
    sb t0, 3(s6)
    sb zero, 4(s6)
    j error_word

error_cstk_underflow:
    addi t0, zero, 117        # 'u'
    sb t0, 0(s6)
    addi t0, zero, 110        # 'n'
    sb t0, 1(s6)
    addi t0, zero, 100        # 'd'
    sb t0, 2(s6)
    addi t0, zero, 102        # 'f'
    sb t0, 3(s6)
    sb zero, 4(s6)
    j error_word

error_patch_overflow:
    addi t0, zero, 112        # 'p'
    sb t0, 0(s6)
    addi t0, zero, 97         # 'a'
    sb t0, 1(s6)
    addi t0, zero, 116        # 't'
    sb t0, 2(s6)
    addi t0, zero, 99         # 'c'
    sb t0, 3(s6)
    addi t0, zero, 104        # 'h'
    sb t0, 4(s6)
    sb zero, 5(s6)
    j error_word

error_call_overflow:
    addi t0, zero, 99         # 'c'
    sb t0, 0(s6)
    addi t0, zero, 97         # 'a'
    sb t0, 1(s6)
    addi t0, zero, 108        # 'l'
    sb t0, 2(s6)
    addi t0, zero, 108        # 'l'
    sb t0, 3(s6)
    sb zero, 4(s6)
    j error_word

error_dict_overflow:
    addi t0, zero, 100        # 'd'
    sb t0, 0(s6)
    addi t0, zero, 105        # 'i'
    sb t0, 1(s6)
    addi t0, zero, 99         # 'c'
    sb t0, 2(s6)
    addi t0, zero, 116        # 't'
    sb t0, 3(s6)
    sb zero, 4(s6)
    j error_word

error_output_overflow:
    addi t0, zero, 102        # 'f'
    sb t0, 0(s6)
    addi t0, zero, 117        # 'u'
    sb t0, 1(s6)
    addi t0, zero, 108        # 'l'
    sb t0, 2(s6)
    addi t0, zero, 108        # 'l'
    sb t0, 3(s6)
    sb zero, 4(s6)
    j error_word

error_unclosed_def:
    addi t0, zero, 100        # 'd'
    sb t0, 0(s6)
    addi t0, zero, 101        # 'e'
    sb t0, 1(s6)
    addi t0, zero, 102        # 'f'
    sb t0, 2(s6)
    sb zero, 3(s6)
    j error_word

error_unmatched_ctrl:
    addi t0, zero, 99         # 'c'
    sb t0, 0(s6)
    addi t0, zero, 116        # 't'
    sb t0, 1(s6)
    addi t0, zero, 114        # 'r'
    sb t0, 2(s6)
    addi t0, zero, 108        # 'l'
    sb t0, 3(s6)
    sb zero, 4(s6)
    j error_word

error_nested_colon:
    addi t0, zero, 110        # 'n'
    sb t0, 0(s6)
    addi t0, zero, 101        # 'e'
    sb t0, 1(s6)
    addi t0, zero, 115        # 's'
    sb t0, 2(s6)
    addi t0, zero, 116        # 't'
    sb t0, 3(s6)
    sb zero, 4(s6)
    j error_word

error_semi_outside:
    addi t0, zero, 59         # ';'
    sb t0, 0(s6)
    sb zero, 1(s6)
    j error_word

# ============================================================================
# Error: print "? <line>: <word>\n" via UART, then halt
# Expects: s5 = UART base, s6 = null-terminated word buffer, gp = line number
# ============================================================================
error_word:
    # Print "? "
    addi t0, zero, 63          # '?'
ew_w1:
    lbu t1, 5(s5)
    andi t1, t1, 32
    beqz t1, ew_w1
    sb t0, 0(s5)
    addi t0, zero, 32          # ' '
ew_w2:
    lbu t1, 5(s5)
    andi t1, t1, 32
    beqz t1, ew_w2
    sb t0, 0(s5)
    # Print line number (decimal) from gp
    # Convert gp to decimal digits on stack, then print them
    addi t2, gp, 0             # t2 = remaining value
    addi t3, zero, 0           # t3 = digit count
ew_div10:
    addi t4, zero, 10
    addi t5, zero, 0           # quotient
    addi t6, t2, 0             # dividend
ew_div_loop:
    blt t6, t4, ew_div_done
    sub t6, t6, t4
    addi t5, t5, 1
    j ew_div_loop
ew_div_done:
    # t5 = quotient, t6 = remainder (digit)
    addi t6, t6, 48            # ASCII digit
    addi s4, s4, -4
    sw t6, 0(s4)               # push digit onto data stack (repurposed as scratch)
    addi t3, t3, 1             # digit count++
    addi t2, t5, 0             # continue with quotient
    bnez t2, ew_div10
    # Print digits (they're on the stack in reverse order, so pop = correct order)
ew_print_digits:
    lw t0, 0(s4)
    addi s4, s4, 4
ew_wd:
    lbu t1, 5(s5)
    andi t1, t1, 32
    beqz t1, ew_wd
    sb t0, 0(s5)
    addi t3, t3, -1
    bnez t3, ew_print_digits
    # Print ": "
    addi t0, zero, 58          # ':'
ew_wc:
    lbu t1, 5(s5)
    andi t1, t1, 32
    beqz t1, ew_wc
    sb t0, 0(s5)
    addi t0, zero, 32          # ' '
ew_ws:
    lbu t1, 5(s5)
    andi t1, t1, 32
    beqz t1, ew_ws
    sb t0, 0(s5)
    # Print word name from word buffer
    addi t2, zero, 0           # index into word buffer
ew_loop:
    add t3, s6, t2
    lbu t0, 0(t3)
    beqz t0, ew_end
ew_w3:
    lbu t1, 5(s5)
    andi t1, t1, 32
    beqz t1, ew_w3
    sb t0, 0(s5)
    addi t2, t2, 1
    j ew_loop
ew_end:
    addi t0, zero, 10          # '\n'
ew_w4:
    lbu t1, 5(s5)
    andi t1, t1, 32
    beqz t1, ew_w4
    sb t0, 0(s5)
error_halt:
    # Shut down QEMU so the compiler exits instead of hanging
    lui t0, 0x100
    lui t1, 5
    addi t1, t1, 0x555
    sw t1, 0(t0)
    j error_halt

# ============================================================================
# PHASE 3: Emit dispatch table and patch return jumps
# ============================================================================
compile_done:
    # Check control stack balance: s9 should equal initial value 0x82800100
    lui t0, 0x82800
    addi t0, t0, 0x100
    beq s9, t0, ctrl_ok
    # Unmatched control structure — store "ctrl" in word buffer and error
    addi t0, zero, 99         # 'c'
    sb t0, 0(s6)
    addi t0, zero, 116        # 't'
    sb t0, 1(s6)
    addi t0, zero, 114        # 'r'
    sb t0, 2(s6)
    addi t0, zero, 108        # 'l'
    sb t0, 3(s6)
    sb zero, 4(s6)
    j error_word
ctrl_ok:
    # The dispatch table goes at the current output position
    addi t2, s3, 0           # t2 = dispatch table start address

    # First, patch all jal-to-dispatch placeholders
    # Patch list starts at 0x82810000, ends at s11
    lui t3, 0x82810           # patch list base: 0x82810000
patch_loop:
    beq t3, s11, emit_dispatch  # done patching
    lw t4, 0(t3)            # address of jal instruction to patch
    # Compute offset from that jal to dispatch table start (t2)
    sub t5, t2, t4           # offset = dispatch - jal_addr
    # Encode as J-type: jal x0, offset
    srli t6, t5, 20
    andi t6, t6, 1
    slli t6, t6, 31

    srli t0, t5, 1
    andi t0, t0, 0x3FF
    slli t0, t0, 21
    or t6, t6, t0

    srli t0, t5, 11
    andi t0, t0, 1
    slli t0, t0, 20
    or t6, t6, t0

    srli t0, t5, 12
    andi t0, t0, 0xFF
    slli t0, t0, 12
    or t6, t6, t0

    addi t0, zero, 0x6F
    or t6, t6, t0
    sw t6, 0(t4)             # patch the instruction

    addi t3, t3, 4
    j patch_loop

# Emit the dispatch table as a binary search tree
# Registers during emit:
#   a0 = work stack pointer (reuses patch list memory at 0x82810000)
#   a1 = current range lo (inclusive)
#   a2 = current range hi (exclusive)
#   a3 = call site list base (0x82850000)
#   a4 = n (hi - lo)
#   a5 = mid
# Each stack frame: { lo (4B), mid (4B), patch_addr (4B) } = 12 bytes
# Emitted tree layout per internal node (n >= 3):
#   li t0, mid          — load comparison ID
#   bne s1, t0, +8      — skip match jal if no match
#   jal x0, call_site   — match: jump to call site
#   bgeu s1, t0, +8     — unsigned: if s1 > mid, skip left, fall to right
#   jal x0, left         — placeholder, patched after right subtree emitted
#   [right subtree]
#   [left subtree]
emit_dispatch:
    beq s10, zero, disp_done

    lui a0, 0x82810
    addi a1, zero, 0
    addi a2, s10, 0
    lui a3, 0x82850

bsearch_loop:
    sub a4, a2, a1

bsearch_descend:
    addi t0, zero, 3
    blt a4, t0, bsearch_small

    # --- Internal node: n >= 3 ---
    srli a5, a4, 1
    add a5, a1, a5

    # Emit: addi x5, x0, mid
    slli t0, a5, 20
    addi t1, zero, 0x13
    ori t1, t1, 0x280
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: bne x9, x5, +8
    lui t0, 0x00549
    addi t0, t0, 0x463
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: jal x0, call_site[mid]
    slli t5, a5, 2
    add t5, a3, t5
    lw t5, 0(t5)
    sub t6, t5, s3
    srli t0, t6, 20
    andi t0, t0, 1
    slli t0, t0, 31
    srli t1, t6, 1
    andi t1, t1, 0x3FF
    slli t1, t1, 21
    or t0, t0, t1
    srli t1, t6, 11
    andi t1, t1, 1
    slli t1, t1, 20
    or t0, t0, t1
    srli t1, t6, 12
    andi t1, t1, 0xFF
    slli t1, t1, 12
    or t0, t0, t1
    addi t1, zero, 0x6F
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: bgeu x9, x5, +8
    lui t0, 0x0054F
    addi t0, t0, 0x463
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: jal x0, 0 (placeholder for left subtree jump)
    addi t0, zero, 0x6F
    sw t0, 0(s3)
    addi s3, s3, 4

    # Push { lo, mid, patch_addr }
    sw a1, 0(a0)
    sw a5, 4(a0)
    addi t0, s3, -4
    sw t0, 8(a0)
    addi a0, a0, 12

    # Descend into right subtree [mid+1, hi)
    addi a1, a5, 1
    sub a4, a2, a1
    j bsearch_descend

bsearch_small:
    addi t0, zero, 2
    beq a4, t0, bsearch_two

    # --- Leaf: n == 1, emit jal x0, call_site[lo] ---
    slli t5, a1, 2
    add t5, a3, t5
    lw t5, 0(t5)
    sub t6, t5, s3
    srli t0, t6, 20
    andi t0, t0, 1
    slli t0, t0, 31
    srli t1, t6, 1
    andi t1, t1, 0x3FF
    slli t1, t1, 21
    or t0, t0, t1
    srli t1, t6, 11
    andi t1, t1, 1
    slli t1, t1, 20
    or t0, t0, t1
    srli t1, t6, 12
    andi t1, t1, 0xFF
    slli t1, t1, 12
    or t0, t0, t1
    addi t1, zero, 0x6F
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4
    j bsearch_pop

bsearch_two:
    # --- Two elements: n == 2 ---
    # Emit: addi x5, x0, lo
    slli t0, a1, 20
    addi t1, zero, 0x13
    ori t1, t1, 0x280
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: bne x9, x5, +8
    lui t0, 0x00549
    addi t0, t0, 0x463
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: jal x0, call_site[lo]
    slli t5, a1, 2
    add t5, a3, t5
    lw t5, 0(t5)
    sub t6, t5, s3
    srli t0, t6, 20
    andi t0, t0, 1
    slli t0, t0, 31
    srli t1, t6, 1
    andi t1, t1, 0x3FF
    slli t1, t1, 21
    or t0, t0, t1
    srli t1, t6, 11
    andi t1, t1, 1
    slli t1, t1, 20
    or t0, t0, t1
    srli t1, t6, 12
    andi t1, t1, 0xFF
    slli t1, t1, 12
    or t0, t0, t1
    addi t1, zero, 0x6F
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4

    # Emit: jal x0, call_site[lo+1]
    addi t2, a1, 1
    slli t5, t2, 2
    add t5, a3, t5
    lw t5, 0(t5)
    sub t6, t5, s3
    srli t0, t6, 20
    andi t0, t0, 1
    slli t0, t0, 31
    srli t1, t6, 1
    andi t1, t1, 0x3FF
    slli t1, t1, 21
    or t0, t0, t1
    srli t1, t6, 11
    andi t1, t1, 1
    slli t1, t1, 20
    or t0, t0, t1
    srli t1, t6, 12
    andi t1, t1, 0xFF
    slli t1, t1, 12
    or t0, t0, t1
    addi t1, zero, 0x6F
    or t0, t0, t1
    sw t0, 0(s3)
    addi s3, s3, 4
    j bsearch_pop

bsearch_pop:
    lui t0, 0x82810
    beq a0, t0, disp_done

    addi a0, a0, -12
    lw a1, 0(a0)
    lw a2, 4(a0)
    lw t2, 8(a0)

    # Patch placeholder jal to jump to current position
    sub t6, s3, t2
    srli t0, t6, 20
    andi t0, t0, 1
    slli t0, t0, 31
    srli t1, t6, 1
    andi t1, t1, 0x3FF
    slli t1, t1, 21
    or t0, t0, t1
    srli t1, t6, 11
    andi t1, t1, 1
    slli t1, t1, 20
    or t0, t0, t1
    srli t1, t6, 12
    andi t1, t1, 0xFF
    slli t1, t1, 12
    or t0, t0, t1
    addi t1, zero, 0x6F
    or t0, t0, t1
    sw t0, 0(t2)

    j bsearch_loop

disp_done:
    # Emit infinite loop as fallthrough safety: j . (jal x0, 0)
    addi t0, zero, 0x6F     # jal x0, offset=0 loops forever
    sw t0, 0(s3)
    addi s3, s3, 4

    # --- Patch auipc/addi for PIC (prologue words 2-3) ---
    # Must happen here (after dispatch table + safety jal) so s3 = true end.
    # offset = code_size - 8 (distance from auipc at word 2 to end of binary)
    sub t0, s3, s8          # t0 = code_size = output_ptr - output_base
    addi t0, t0, -8         # t0 = offset from auipc to here

    # Split into upper20 + lower12 with sign-extension adjustment
    slli t1, t0, 20
    srli t1, t1, 20          # t1 = lower 12 bits
    srli t2, t0, 12          # t2 = upper 20 bits (no adjustment yet)
    srli t3, t0, 11
    andi t3, t3, 1            # t3 = bit 11 (sign of lower12)
    add t2, t2, t3            # t2 = adjusted upper20

    # Build auipc x5, upper20: (upper20 << 12) | 0x297
    slli t4, t2, 12
    addi t5, zero, 0x297     # (5 << 7) | 0x17
    or t4, t4, t5
    addi t5, s8, 8           # address of word 2 in output buffer
    sw t4, 0(t5)             # patch auipc

    # Build addi x5, x5, lower12: (lower12 << 20) | 0x00028293
    slli t4, t1, 20
    lui t5, 0x00028
    addi t5, t5, 0x293       # 0x00028293 = addi x5, x5, 0
    or t4, t4, t5
    addi t5, s8, 12          # address of word 3 in output buffer
    sw t4, 0(t5)             # patch addi

# ============================================================================
# PHASE 4: Output compiled binary via UART
# ============================================================================
    lui s1, 0x84000          # output buffer base (read pointer)
    # s3 = end of output

output_loop:
    beq s1, s3, shutdown     # done?
    lbu t3, 0(s1)            # load byte
    addi s1, s1, 1

output_retry:
    lbu t0, 5(s5)            # check LSR
    andi t0, t0, 32          # THR empty?
    beqz t0, output_retry    # wait
    sb t3, 0(s5)             # send byte
    j output_loop

# ============================================================================
# PHASE 5: Shutdown (QEMU virt poweroff)
# ============================================================================
shutdown:
    lui s5, 0x100            # QEMU test device
    lui t0, 0x5              # FINISHER_PASS
    addi t0, t0, 0x555
    sw t0, 0(s5)             # power off
